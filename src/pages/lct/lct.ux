        <div class="page1" for="{{pages}}" tid="name">
          <div class="content1">
            <text class="mid1">{{$item.name}}</text>
          </div>
          <scroll class="chapter-scroll" scroll-y="{{true}}" bounces="false">
            <div for="{{$item.chapters}}" tid="line" class="content" onclick="loadStart($item.line)">
              <text class="mid">{{$item.label}}</text>
            </div>
            <text class="mid" if="{{$item.hasAfter}}" onclick="loadStart($item.afterLine)">后日谈</text>
          </scroll>
        </div>
