  onDestroy() {
    if (this.switchTimer) {
      clearTimeout(this.switchTimer)
      this.switchTimer = null
    }
  },

  onSwiperChange(e) {
    if (this.switchTimer) {
      clearTimeout(this.switchTimer)
    }
    this.isSwitching = true
    this.page = e.index
    this.switchTimer = setTimeout(() => {
      this.isSwitching = false
      this.switchTimer = null
    }, 150)
  },

  loadStart(a) {
    if (this.isSwitching) return
    try {
      storage.set({
        key: 'readProgress',
        value: a.toString(),
        success: () => {},
        fail: () => {}
      })
      router.push({ uri: 'pages/detail' })
    } catch (e) {
      console.error('跳转失败:', e)
    }
  },

  back() {
    router.back()
  }
}
</script>

