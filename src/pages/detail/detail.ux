<script>
  import prompt from '@system.prompt'
  import brightness from '@system.brightness'
  import storage from '@system.storage'
  import router from '@system.router'
  import file from '@system.file'
  import { SETTINGS_CONFIG, DEFAULT_SAVE_SLOTS, MAX_SAVE_SLOTS } from '../../common/config.js'

  class GameScriptLoader {
    constructor() {
      this.scripts = {}
      this.isLoaded = false
      this.loadPromise = null
      this.chunkSize = 500
      this.maxRetries = 2
      this.retryDelay = 150
      this.loadedChunks = {}
      this.currentChunk = 1
      this.pendingLoads = {}
      this.totalScriptsCount = 0
      this.lastMemoryCheck = 0
    }

    async loadGameScript() {
      if (this.loadPromise) return this.loadPromise
      if (this.isLoaded) return true
      this.loadPromise = new Promise(async (resolve) => {
        try {
          console.log('启动游戏脚本加载...')
          this.scripts = {}
          this.loadedChunks = {}
          await this.loadMinimalChunk(1)
          this.isLoaded = true
          console.log('游戏脚本极简加载完成')
          resolve(true)
        } catch (e) {
          console.error('游戏脚本加载失败，使用备用脚本:', e)
          this.scripts = this.getEssentialScripts()
          this.isLoaded = true
          console.log('使用备用脚本数据')
          resolve(true)
        } finally {
          this.loadPromise = null
        }
      })
      return this.loadPromise
    }

    async loadMinimalChunk(chunkNum) {
      if (this.loadedChunks[chunkNum]) return true
      if (this.pendingLoads[chunkNum]) {
        return new Promise((resolve) => {
          let checkInterval = setInterval(() => {
            if (this.loadedChunks[chunkNum]) {
              clearInterval(checkInterval)
              resolve(true)
            }
          }, 50)
        })
      }
      this.pendingLoads[chunkNum] = true
      return new Promise((resolve) => {
        let filePath = `/common/script/scriptData${chunkNum}.txt`
        file.readText({
          uri: filePath,
          success: (data) => {
            try {
              let text = typeof data === 'string' ? data : (data.text || '')
              let parsed = this.parseChunkMinimal(text, chunkNum)
              this.addScriptsSparse(parsed)
              this.loadedChunks[chunkNum] = true
              this.totalScriptsCount += Object.keys(parsed).length
              console.log(`块 ${chunkNum} 精简加载完成，新增 ${Object.keys(parsed).length} 个脚本`)
              this.cleanupOldChunks(chunkNum)
              resolve(true)
            } catch (e) {
              console.error(`处理块 ${chunkNum} 失败:`, e)
              this.loadedChunks[chunkNum] = true
              resolve(false)
            } finally {
              delete this.pendingLoads[chunkNum]
            }
          },
          fail: (err) => {
            console.error(`加载块 ${chunkNum} 失败:`, err)
            this.loadedChunks[chunkNum] = true
            delete this.pendingLoads[chunkNum]
            resolve(false)
          }
        })
      })
    }

    parseChunkMinimal(text, chunkNum) {
      if (!text || text.trim() === '') return {}
      let cleaned = text.trim()
      if (cleaned.charCodeAt(0) === 65279) cleaned = cleaned.substring(1)
      if (cleaned.startsWith('{') && cleaned.endsWith('}')) {
        try { return JSON.parse(cleaned) } catch (e) { console.error(`解析块 ${chunkNum} JSON失败:`, e) }
      }
      return {}
    }

    addScriptsSparse(newScripts) {
      for (let key in newScripts) {
        if (newScripts.hasOwnProperty(key)) {
          this.scripts[key] = newScripts[key]
        }
      }
    }

    cleanupOldChunks(currentChunk) {
      let keepChunks = { [currentChunk]: true, [currentChunk - 1]: true, [currentChunk + 1]: true }
      for (let chunkId in this.loadedChunks) {
        let id = parseInt(chunkId)
        if (!keepChunks[id]) {
          this.removeChunkScripts(id)
          delete this.loadedChunks[chunkId]
        }
      }
    }

    removeChunkScripts(chunkNum) {
      let start = (chunkNum - 1) * this.chunkSize + 1
      let end = chunkNum * this.chunkSize
      let removed = 0
      for (let i = start; i <= end; i++) {
        let key = i.toString()
        if (this.scripts[key]) {
          delete this.scripts[key]
          removed++
        }
      }
      if (removed > 0) console.log(`清理块 ${chunkNum}，释放 ${removed} 个脚本`)
    }

    async smartLoadForProgress(progress) {
      let targetChunk = Math.ceil(progress / this.chunkSize)
      if (targetChunk !== this.currentChunk) this.currentChunk = targetChunk
      if (!this.loadedChunks[targetChunk]) await this.loadMinimalChunk(targetChunk)
      let offset = progress % this.chunkSize || this.chunkSize
      if (offset >= this.chunkSize - 10) {
        let nextChunk = targetChunk + 1
        if (!this.loadedChunks[nextChunk] && !this.pendingLoads[nextChunk]) {
          setTimeout(() => { this.loadMinimalChunk(nextChunk).catch(() => {}) }, 100)
        }
      } else if (offset <= 10 && targetChunk > 1) {
        let prevChunk = targetChunk - 1
        if (!this.loadedChunks[prevChunk] && !this.pendingLoads[prevChunk]) {
          setTimeout(() => { this.loadMinimalChunk(prevChunk).catch(() => {}) }, 100)
        }
      }
    }

    async getScript(id) {
      let key = id.toString()
      if (!this.isLoaded) return this.getFallbackScript(id)
      await this.smartLoadForProgress(id)
      let raw = this.scripts[key]
      if (!raw) {
        console.warn(`脚本 ${id} 不存在`)
        return this.getFallbackScript(id)
      }
      return {
        id: id,
        background: raw.b ? `/common/bcgi/${raw.b}.jpg` : '',
        character: raw.c ? `/common/cimg/${raw.c}.png` : '',
        cg: raw.cg ? `/common/evig/${raw.cg}` : '',
        speaker: raw.s || '',
        text: raw.t || '',
        z: raw.z || 0,
        choose: !!raw.co,
        choose1: raw.c1 || '',
        choose2: raw.c2 || '',
        choose3: raw.c3 || '',
        choose4: raw.c4 || '',
        choose5: raw.c5 || '',
        choose1To: raw.c1t || id,
        choose2To: raw.c2t || id,
        choose3To: raw.c3t || id,
        choose4To: raw.c4t || id,
        choose5To: raw.c5t || id
      }
    }

    getFallbackScript(id = 0) {
      return {
        id: id,
        background: '/common/bcgi/画面_白.jpg',
        character: '',
        cg: '',
        speaker: '',
        text: '（脚本加载失败，显示备用内容）',
        z: 0,
        choose: false,
        choose1: '', choose2: '', choose3: '', choose4: '', choose5: '',
        choose1To: id || 0, choose2To: id || 0, choose3To: id || 0, choose4To: id || 0, choose5To: id || 0
      }
    }

    getEssentialScripts() {
      return {
        1: { b: '異世界_前景a', s: '系统', t: '游戏启动中...' },
        2: { b: '異世界_前景a', s: '', t: '请稍候...' },
        3: { b: '異世界_前景a', s: '', t: '正在初始化...' }
      }
    }

    hasNext(id) {
      let nextId = (parseInt(id) + 1).toString()
      return this.scripts.hasOwnProperty(nextId)
    }

    getNextProgressId(id) {
      let nextId = parseInt(id) + 1
      return this.scripts.hasOwnProperty(nextId.toString()) ? nextId : null
    }

    getTotalProgress() {
      return this.totalScriptsCount
    }

    forceCleanup() {
      let chunk = this.currentChunk
      let start = (chunk - 1) * this.chunkSize + 1
      let end = chunk * this.chunkSize
      let newScripts = {}
      let count = 0
      for (let i = start; i <= end; i++) {
        let key = i.toString()
        if (this.scripts[key]) {
          newScripts[key] = this.scripts[key]
          count++
        }
      }
      this.scripts = newScripts
      this.loadedChunks = { [chunk]: true }
      this.totalScriptsCount = count
      console.log(`强制内存清理完成，保留 ${count} 个脚本`)
    }

    getMemoryStatus() {
      let chunks = []
      for (let id in this.loadedChunks) chunks.push(parseInt(id))
      return {
        loadedChunks: chunks.length,
        totalScripts: this.totalScriptsCount,
        currentChunk: this.currentChunk,
        memory: `${Math.round(this.totalScriptsCount * 0.3)}KB`
      }
    }

    async preloadRange(startId, endId) {
      let startChunk = Math.ceil(startId / this.chunkSize)
      let endChunk = Math.ceil(endId / this.chunkSize)
      let loaded = 0
      for (let c = startChunk; c <= endChunk && loaded < 3; c++) {
        if (!this.loadedChunks[c]) {
          await this.loadMinimalChunk(c)
          loaded++
        }
      }
      if (loaded > 0) console.log(`预加载完成，加载了 ${loaded} 个块`)
    }

    clearAll() {
      this.scripts = {}
      this.loadedChunks = {}
      this.pendingLoads = {}
      this.totalScriptsCount = 0
      console.log('所有内存已清空')
    }
  }

