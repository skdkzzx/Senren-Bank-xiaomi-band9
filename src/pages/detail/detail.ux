      progressSaveTimer: null,
      imageCache: {},
      maxImageCacheSize: 8,
      currentImageKeys: [],
      isPreloadingImages: false,
      imageMemoryUsage: 0,
      maxImageMemory: 0xf00000,
      lastImageCleanup: 0,
      imageCleanupInterval: 5000,
      imageLoadSuccess: 0,
      imageLoadFail: 0,
      lowMemoryMode: false,
      forceImageCleanupThreshold: 0.8,
      fontParseCache: {},
      fontParseCacheOrder: [],
      isEnding: false,
      endText: '',
      endAnimationDone: false,
      flashbangPages: [],
      showFlashbang: false,
      flashbangOpacity: 1,
      flashbangTimer: null,
      isFlashActive: false,
      waitForFlashbang: false
    },

    parseTextFontSize(text) {
      if (!text) return { fontSize: this.fontSize, text: '' }
      if (this.fontParseCache[text]) return this.fontParseCache[text]
      let fontSize = this.fontSize
      let displayText = text
      let match = text.match(/^%(\d+)\s*(.*)/)
      if (match) {
        let percent = parseInt(match[1])
        fontSize = Math.max(10, Math.min(100, Math.floor(this.fontSize * percent / 100)))
        displayText = match[2]
      }
      let result = { fontSize: fontSize, text: displayText }
      if (this.fontParseCacheOrder.length > 200) {
        let oldest = this.fontParseCacheOrder.shift()
        delete this.fontParseCache[oldest]
      }
      this.fontParseCache[text] = result
      this.fontParseCacheOrder.push(text)
      return result
    },

    getCharacterScaleClass(z) {
      if (z === 1) return 'character-scale-07'
      if (z === 2) return 'character-scale-12'
      return 'character-scale-1'
    },

    getBackgroundScaleClass(z) {
      return z === 2 ? 'bg-scale-11' : 'bg-scale-1'
    },

    updateImageIfNeeded(prop, newUrl, type) {
      if (this[prop] === newUrl) return false
      this[prop] = newUrl
      if (newUrl) this.addToImageCache(newUrl, type)
      return true
    },

    getImageKey(url) {
      if (!url) return null
      let key = url.split('?')[0]
      return key.split('/').pop() || key
    },

    estimateImageSize(url) {
      if (!url) return 0
      let isPng = url.includes('.png')
      let isJpg = url.includes('.jpg') || url.includes('.jpeg')
      if (isPng) return 51200
      if (isJpg) return url.includes('bcgi') ? 30720 : (url.includes('evig') ? 40960 : 20480)
      return 30720
    },

    addToImageCache(url, type = 'unknown', isPreload = false) {
      if (!url) return false
      let key = this.getImageKey(url)
      if (!key) return false
      if (this.imageCache[key]) {
        this.imageCache[key].lastUsed = Date.now()
        this.imageCache[key].isPreload = isPreload
        return true
      }
      let size = this.estimateImageSize(url)
      if (this.imageMemoryUsage + size > this.maxImageMemory * 0.9) {
        this.cleanupImagesByPriority(2)
      }
      this.imageCache[key] = {
        url: url, loaded: false, lastUsed: Date.now(), size: size,
        type: type, isPreload: isPreload, priority: this.getImagePriority(type, isPreload)
      }
      this.imageMemoryUsage += size
      return true
    },

    getImagePriority(type, isPreload) {
      if (isPreload) return 1
      switch (type) {
        case 'background': return 10
        case 'cg': return 8
        case 'character': return 6
        default: return 3
      }
    },

    markImageAsUsed(url, type) {
      if (!url) return
      let key = this.getImageKey(url)
      if (!key || !this.imageCache[key]) return
      this.imageCache[key].lastUsed = Date.now()
      this.imageCache[key].priority = this.getImagePriority(type, false)
      this.imageCache[key].isPreload = false
      this.addToCurrentImageList(key)
      if (this.currentImageKeys.length > 4) {
        let removed = this.currentImageKeys.shift()
        if (removed && this.imageCache[removed]) {
          this.imageCache[removed].priority = Math.max(1, this.imageCache[removed].priority - 2)
        }
      }
    },

    addToCurrentImageList(key) {
      let idx = this.currentImageKeys.indexOf(key)
      if (idx !== -1) this.currentImageKeys.splice(idx, 1)
      this.currentImageKeys.push(key)
    },

    cleanupImagesByPriority(count = 1) {
      let now = Date.now()
      if (now - this.lastImageCleanup < this.imageCleanupInterval) return
      this.lastImageCleanup = now
      let candidates = Object.entries(this.imageCache).filter(([k, v]) =>
        !this.currentImageKeys.includes(k) && now - v.lastUsed > 5000
      )
      if (candidates.length === 0) return
      candidates.sort((a, b) =>
        a[1].priority !== b[1].priority ? a[1].priority - b[1].priority : a[1].lastUsed - b[1].lastUsed
      )
      let toRemove = candidates.slice(0, Math.min(count, candidates.length))
      let freed = 0
      toRemove.forEach(([k, v]) => {
        freed += v.size || 0
        delete this.imageCache[k]
      })
      this.imageMemoryUsage = Math.max(0, this.imageMemoryUsage - freed)
      if (this.imageMemoryUsage > this.maxImageMemory * this.forceImageCleanupThreshold) {
        this.forceCleanupExcessImages()
      }
    },

    forceCleanupExcessImages() {
      let excess = this.imageMemoryUsage - 0.8 * this.maxImageMemory
      if (excess <= 0) return
      let freed = 0
      for (let [k, v] of Object.entries(this.imageCache)
        .filter(([k]) => !this.currentImageKeys.includes(k))
        .sort((a, b) => 1000 * a[1].priority + a[1].lastUsed - (1000 * b[1].priority + b[1].lastUsed))) {
        if (freed >= excess) break
        freed += v.size || 0
        delete this.imageCache[k]
      }
      this.imageMemoryUsage = Math.max(0, this.imageMemoryUsage - freed)
      if (freed > 0) this.lowMemoryMode = true
    },

    async smartPreloadImages(script, progressId) {
      if (!script || !this.gameEngine || this.imageMemoryUsage > this.maxImageMemory * 0.7) return
      let preloadItems = []
      if (script.background) preloadItems.push({ url: script.background, type: 'background' })
      if (script.cg) preloadItems.push({ url: script.cg, type: 'cg' })
      if (script.character) preloadItems.push({ url: script.character, type: 'character' })
      preloadItems.forEach(item => this.addToImageCache(item.url, item.type, true))
      if (this.isPreloadingImages || this.lowMemoryMode) return
      this.isPreloadingImages = true
      setTimeout(async () => {
        try {
          for (let i = 1; i <= 2; i++) {
            let nextId = progressId + i
            let nextScript = await this.gameEngine.getScript(nextId)
            if (nextScript) {
              if (nextScript.background && nextScript.background !== script.background) this.addToImageCache(nextScript.background, 'background', true)
              if (nextScript.cg && nextScript.cg !== script.cg) this.addToImageCache(nextScript.cg, 'cg', true)
              if (nextScript.character && nextScript.character !== script.character) this.addToImageCache(nextScript.character, 'character', true)
            }
            if (this.imageMemoryUsage > this.maxImageMemory * 0.6) break
          }
        } catch (e) {} finally {
          this.isPreloadingImages = false
        }
      }, 300)
    },

    onImageLoad(type, url) {
      this.imageLoadSuccess++
      let key = this.getImageKey(url)
      if (key && this.imageCache[key]) this.imageCache[key].loaded = true
      this.markImageAsUsed(url, type)
    },

    onImageError(type, url) {
      let key = this.getImageKey(url)
      if (key && this.imageCache[key]) {
        this.imageCache[key].failed = true
        this.imageCache[key].priority = -1
      }
      switch (type) {
        case 'background': if (this.currentBackground === url) this.currentBackground = ''; break
        case 'nextBackground': if (this.nextBackground === url) { this.nextBackground = ''; this.showNextBackground = false } break
        case 'cg': if (this.cgimg === url) this.cgimg = ''; break
        case 'nextCg': if (this.nextCg === url) { this.nextCg = ''; this.showNextCg = false } break
        case 'character': if (this.characterimg === url) this.characterimg = ''; break
        case 'nextCharacter': if (this.nextCharacterImg === url) { this.nextCharacterImg = ''; this.showNextCharacter = false } break
      }
    },

    getImageCacheStatus() {
      let total = Object.keys(this.imageCache).length
      return {
        total: total,
        loaded: Object.values(this.imageCache).filter(v => v.loaded).length,
        preload: Object.values(this.imageCache).filter(v => v.isPreload).length,
        current: this.currentImageKeys.length,
        memory: `${Math.round(this.imageMemoryUsage / 1024)}KB/${Math.round(this.maxImageMemory / 1024)}KB`,
        usage: Math.round(this.imageMemoryUsage / this.maxImageMemory * 100),
        success: this.imageLoadSuccess,
        fail: this.imageLoadFail
      }
    },

    startBgScroll() {
      this.stopBgScroll()
      this.bgLeft = 0
      this.bgScrollDir = 1
      this.bgScrollTimer = setInterval(() => {
        let speed = this.bgScrollSpeed * 0.184
        this.bgLeft += this.bgScrollDir * speed
        if (this.bgLeft <= -144) { this.bgLeft = -144; this.bgScrollDir = 1 }
        if (this.bgLeft >= 0) { this.bgLeft = 0; this.bgScrollDir = -1 }
        try {
          let el = this.$element('bgScroll')
          if (el) el.scrollTo({ left: Math.abs(this.bgLeft) })
        } catch (e) {}
      }, 33)
    },

    stopBgScroll() {
      if (this.bgScrollTimer) { clearInterval(this.bgScrollTimer); this.bgScrollTimer = null }
    },

    startCgScroll() {
      this.stopCgScroll()
      if (!this.bgScrollEnabled || !this.cgimg) return
      this.cgLeft = 0
      this.cgScrollDir = 1
      let maxScroll = this.cgContentWidth - 192
      if (maxScroll <= 0) return
      this.cgScrollTimer = setInterval(() => {
        let speed = this.bgScrollSpeed * 0.184
        this.cgLeft += this.cgScrollDir * speed
        if (this.cgLeft <= -maxScroll) { this.cgLeft = -maxScroll; this.cgScrollDir = 1 }
        if (this.cgLeft >= 0) { this.cgLeft = 0; this.cgScrollDir = -1 }
        try {
          let el = this.$element('cgScroll')
          if (el) el.scrollTo({ left: Math.abs(this.cgLeft) })
        } catch (e) {}
      }, 33)
    },

    stopCgScroll() {
      if (this.cgScrollTimer) { clearInterval(this.cgScrollTimer); this.cgScrollTimer = null }
    },

    onCgImageComplete(e) {
      if (e && e.width && e.height) {
        let isPng = this.cgimg && this.cgimg.includes('.png')
        if (isPng) {
          this.cgContentWidth = Math.max(192, Math.ceil(490 * e.width / e.height))
          this.cgObjectFit = 'contain'
        } else {
          this.cgContentWidth = 336
          this.cgObjectFit = 'cover'
        }
      }
    },

    startSplashCountdown() {
      storage.get({
        key: 'splashShown',
        success: (data) => {
          if (data === 'true') return
          this.showSplash = true
          this.splashReady = false
          this.splashCountdown = 5
          this.splashTimer = setInterval(() => {
            this.splashCountdown--
            if (this.splashCountdown <= 0) {
              clearInterval(this.splashTimer)
              this.splashTimer = null
              this.splashReady = true
            }
          }, 1000)
        },
        fail: () => {
          this.showSplash = true
          this.splashReady = false
          this.splashCountdown = 5
          this.splashTimer = setInterval(() => {
            this.splashCountdown--
            if (this.splashCountdown <= 0) {
              clearInterval(this.splashTimer)
              this.splashTimer = null
              this.splashReady = true
            }
          }, 1000)
        }
      })
    },

    closeSplash() {
      if (!this.splashReady) return
      this.showSplash = false
      if (this.splashTimer) { clearInterval(this.splashTimer); this.splashTimer = null }
      storage.set({ key: 'splashShown', value: 'true' })
    },

    cleanupFlashbang() {
      if (this.flashbangTimer) { clearTimeout(this.flashbangTimer); this.flashbangTimer = null }
      if (this.showFlashbang) this.showFlashbang = false
      this.isFlashActive = false
      if (this.waitForFlashbang) this.startTypewriterAfterFlashbang()
    },

    startTypewriterAfterFlashbang() {
      if (!this.waitForFlashbang) return
      this.waitForFlashbang = false
      this.displayCharacter = this.character
      this.displayText = ''
      this.currentTextIndex = 0
      this.startTypewriter()
    },

    triggerFlashbang() {
      if (this.isFlashActive) this.cleanupFlashbang()
      if (this.isEnding || this.isAnimating) return
      this.isFlashActive = true
      this.showFlashbang = true
      this.flashbangOpacity = 1
      let opacity = 1
      if (this.flashbangTimer) clearTimeout(this.flashbangTimer)
      this.flashbangTimer = setInterval(() => {
        opacity -= 0.05
        if (opacity <= 0) {
          clearInterval(this.flashbangTimer)
          this.flashbangTimer = null
          this.cleanupFlashbang()
        } else {
          this.flashbangOpacity = opacity
        }
      }, 20)
    },

    getBlockIndex(id) { return Math.floor((id - 1) / this.blockSize) },
    getBlockOffset(id) { return (id - 1) % this.blockSize },
    shouldSaveBlock(blockIndex, offset) { return offset <= this.saveThreshold || offset >= this.blockSize - this.saveThreshold },

    async loadBlock(blockIndex) {
      if (this.readBlocks[blockIndex]) return true
      return new Promise((resolve) => {
        storage.get({
          key: `readBlock_${blockIndex}`,
          success: (data) => {
            try {
              if (data) {
                this.readBlocks[blockIndex] = JSON.parse(data)
              } else {
                this.readBlocks[blockIndex] = Array(this.blockSize).fill(false)
              }
              resolve(true)
            } catch (e) {
              this.readBlocks[blockIndex] = Array(this.blockSize).fill(false)
              resolve(true)
            }
          },
          fail: () => {
            this.readBlocks[blockIndex] = Array(this.blockSize).fill(false)
            resolve(true)
          }
        })
      })
    },

    markBlockForSave(blockIndex) {
      if (!this.readBlocks[blockIndex]) return
      this.pendingSaves[blockIndex] = [...this.readBlocks[blockIndex]]
    },

    async savePendingBlocks() {
      let keys = Object.keys(this.pendingSaves)
      if (keys.length === 0) return
      let promises = []
      for (let key of keys) {
        let storageKey = `readBlock_${key}`
        let data = this.pendingSaves[key]
        let p = new Promise((resolve) => {
          storage.set({
            key: storageKey,
            value: JSON.stringify(data),
            success: () => { delete this.pendingSaves[key]; resolve(true) },
            fail: () => resolve(false)
          })
        })
        promises.push(p)
      }
      await Promise.all(promises)
    },

    async saveOnBlockTransition(id) {
      let newBlock = this.getBlockIndex(id)
      let oldBlock = this.currentBlockIndex
      if (newBlock !== oldBlock && this.readBlocks[oldBlock]) {
        this.markBlockForSave(oldBlock)
        await this.savePendingBlocks()
      }
      this.currentBlockIndex = newBlock
    },

    async preloadAdjacentBlocks(id) {
      let blockIndex = this.getBlockIndex(id)
      let offset = this.getBlockOffset(id)
      if (offset >= this.blockSize - this.preloadDistance) {
        let next = blockIndex + 1
        if (!this.readBlocks[next]) this.loadBlock(next)
      }
      if (offset <= this.preloadDistance && blockIndex > 0) {
        let prev = blockIndex - 1
        if (!this.readBlocks[prev]) this.loadBlock(prev)
      }
    },

    smartCleanBlocks(id) {
      let current = this.getBlockIndex(id)
      let keep = [current, current - 1, current + 1]
      Object.keys(this.readBlocks).forEach((key) => {
        let idx = parseInt(key)
        if (!keep.includes(idx)) delete this.readBlocks[idx]
      })
    },

    async markPageAsRead(id) {
      if (!id) return
      let blockIndex = this.getBlockIndex(id)
      let offset = this.getBlockOffset(id)
      if (!this.readBlocks[blockIndex]) await this.loadBlock(blockIndex)
      if (this.readBlocks[blockIndex] && this.readBlocks[blockIndex][offset] !== true) {
        this.readBlocks[blockIndex][offset] = true
        if (this.shouldSaveBlock(blockIndex, offset)) this.markBlockForSave(blockIndex)
        this.preloadAdjacentBlocks(id)
        if (offset >= this.preloadDistance && offset <= this.blockSize - this.preloadDistance) {
          this.smartCleanBlocks(id)
        }
      }
    },

    async isPageRead(id) {
      if (!id) return false
      let blockIndex = this.getBlockIndex(id)
      let offset = this.getBlockOffset(id)
      if (this.readBlocks[blockIndex]) return this.readBlocks[blockIndex][offset] === true
      await this.loadBlock(blockIndex)
      return this.readBlocks[blockIndex] && this.readBlocks[blockIndex][offset] === true
    },

    async loadReadPages() {
      return new Promise((resolve) => {
        let blockIndex = this.getBlockIndex(this.readProgress)
        this.currentBlockIndex = blockIndex
        let blocks = [blockIndex]
        if (blockIndex > 0) blocks.push(blockIndex - 1)
        Promise.all(blocks.map(b => this.loadBlock(b))).then(() => resolve()).catch(() => resolve())
      })
    },

    setKeepScreenOn(on) {
      try { brightness.setKeepScreenOn({ keepScreenOn: on }) } catch (e) { console.warn('屏幕常亮设置失败（不影响游戏）:', e) }
    },

    updateTime() {
      let now = new Date()
      let h = now.getHours()
      let m = now.getMinutes()
      h = h < 10 ? '0' + h : h
      m = m < 10 ? '0' + m : m
      this.nowTime = `${h}:${m}`
    },

    checkSpecialJump(id, direction) {
      if (direction === 'next' && this.branchConfig.noNextPages[id]) return this.branchConfig.noNextPages[id]
      if (direction === 'back' && this.branchConfig.noBackPages[id]) return this.branchConfig.noBackPages[id]
      return null
    },

    checkHiddenPage(id) {
      let key = id.toString()
      if (this.branchConfig.hiddenPages && this.branchConfig.hiddenPages[key]) {
        let fn = this.branchConfig.hiddenPages[key]
        try {
          let result = fn(this.branchConfig.choices || {})
          let num = Number(result)
          return Number.isFinite(num) && !Number.isNaN(num) ? num : id
        } catch (e) {}
      }
      return id
    },

    checkEndPage(id) {
      return this.branchConfig.end[id] || null
    },

    recordChoice(id, choice) {
      this.branchConfig.choices[id] = choice
      storage.set({ key: 'branchChoices', value: JSON.stringify(this.branchConfig.choices) })
    },

    debouncedSaveProgress() {
      if (this.progressSaveTimer) clearTimeout(this.progressSaveTimer)
      this.progressSaveTimer = setTimeout(() => { this.saveProgressToStorage() }, this.progressSaveDelay)
    },

    startBackgroundAnimation(newBg, newCg, newChar, speaker, text, progressId, charScale, bgScale, fontSize) {
      if (this.isAnimating) this.finishAnimation()
      this.isAnimating = true
      this.animationStep = 0
      this.nextBackground = newBg
      this.nextCg = newCg
      this.nextCharacterImg = newChar
      this.nextCharacterScaleClass = charScale
      this.nextBackgroundScaleClass = bgScale
      this.bgLeft = 0
      this.bgScrollDir = 1
      this.cgLeft = 0
      this.cgScrollDir = 1
      this.startBgScroll()
      if (newBg) this.addToImageCache(newBg, 'background')
      if (newCg) this.addToImageCache(newCg, 'cg')
      if (newChar) this.addToImageCache(newChar, 'character')
      this.character = speaker
      this.contect = text
      this.animatingProgressId = progressId
      this.currentTextFontSize = fontSize
      this.playAnimation()
    },

    playAnimation() {
      if (!this.isAnimating) return
      if (this.animationTimer) clearTimeout(this.animationTimer)
      if (this.animationStep <= 10) {
        let opacity = (0.1 * this.animationStep).toFixed(2)
        this.maskColor = `rgba(0, 0, 0, ${opacity})`
        this.hideText = true
        if (this.animationStep === 10) {
          if (this.nextBackground) this.showNextBackground = true
          if (this.nextCg) this.showNextCg = true
          if (this.nextCharacterImg) this.showNextCharacter = true
          this.characterimg = ''
          this.cgimg = ''
          this.stopCgScroll()
          this.displayCharacter = this.character
          this.displayText = ''
          this.cleanupImagesByPriority(1)
        }
        this.animationStep++
      } else if (this.animationStep <= 20) {
        let opacity = ((20 - this.animationStep) * 0.1).toFixed(2)
        this.maskColor = `rgba(0, 0, 0, ${opacity})`
        if (this.animationStep === 20) {
          if (this.nextBackground) {
            this.currentBackground = this.nextBackground
            this.currentBackgroundScaleClass = this.nextBackgroundScaleClass
            this.showNextBackground = false
          }
          if (this.nextCg) { this.cgimg = this.nextCg }
          this.showNextCg = false
          if (this.nextCharacterImg) {
            this.characterimg = this.nextCharacterImg
            this.currentCharacterScaleClass = this.nextCharacterScaleClass
          }
          this.showNextCharacter = false
          this.hideText = false
          this.startCgScroll()
        }
        this.animationStep++
      } else {
        this.finishAnimation()
        return
      }
      this.animationTimer = setTimeout(() => this.playAnimation(), 30)
    },

    finishAnimation() {
      this.isAnimating = false
      this.hideText = false
      this.maskColor = 'rgba(0, 0, 0, 0.0)'
      this.showNextBackground = false
      this.showNextCg = false
      this.showNextCharacter = false
      this.nextCg = ''
      this.nextCharacterImg = ''
      this.nextCharacterScaleClass = ''
      this.nextBackgroundScaleClass = ''
      this.bgLeft = 0
      this.bgScrollDir = 1
      this.cgLeft = 0
      this.cgScrollDir = 1
      if (this.isEnding) {
        this.endAnimationDone = true
      } else {
        if (this.animatingProgressId) {
          this.isPageRead(this.animatingProgressId).then(r => this.viewed = r).catch(() => this.viewed = false)
          this.animatingProgressId = null
        }
        if (this.waitForFlashbang) {
          this.displayCharacter = ''
          this.displayText = ''
        } else {
          this.startTypewriter()
        }
      }
    },

    quickgo() {
      if (this.isGoing) this.stopQuickGo()
      else this.startQuickGo()
      this.contrlcenterShow = false
    },

    startQuickGo() {
      this.toTop()
      this.stopAutoplay()
      this.stopQuickBack()
      this.isGoing = true
      this.quickNavigationCache = {}
      this.quickNavigationQueue = []
      this.quickSpeed = 50
      this.scheduleNextQuickPage()
    },

    stopQuickGo() {
      this.isGoing = false
      if (this.goTimer) clearTimeout(this.goTimer)
    },

    scheduleNextQuickPage() {
      if (!this.isGoing) return
      if (this.goTimer) clearTimeout(this.goTimer)
      this.goTimer = setTimeout(() => { if (this.isGoing) this.nextQuickPage() }, this.quickSpeed)
    },

    async nextQuickPage() {
      if (this.isTyping) {
        if (this.skipOnlyRead && !(await this.isPageRead(this.readProgress))) {
          this.stopQuickGo(); return
        }
        this.skipTyping()
      }
      if (!this.skipOnlyRead) await this.markPageAsRead(this.readProgress)
      let end = this.checkEndPage(this.readProgress)
      if (end) { this.triggerEndSequence(end); return }
      let hidden = this.checkHiddenPage(this.readProgress)
      if (hidden !== this.readProgress) {
        this.readProgress = hidden
        await this.saveOnBlockTransition(this.readProgress)
        await this.loadQuickPage(this.readProgress)
        this.scheduleNextQuickPage(); return
      }
      let special = this.checkSpecialJump(this.readProgress, 'next')
      if (special != null) {
        this.readProgress = special
        await this.saveOnBlockTransition(this.readProgress)
        await this.loadQuickPage(this.readProgress)
        this.scheduleNextQuickPage(); return
      }
      if (this.choose) { this.stopQuickGo(); return }
      this.readProgress++
      if (this.skipOnlyRead && !(await this.isPageRead(this.readProgress))) {
        this.stopQuickGo(); return
      }
      await this.saveOnBlockTransition(this.readProgress)
      await this.loadQuickPage(this.readProgress)
      this.scheduleNextQuickPage()
    },

    quickback() {
      if (this.isBacking) this.stopQuickBack()
      else this.startQuickBack()
      this.contrlcenterShow = false
    },

    startQuickBack() {
      this.toTop()
      this.stopAutoplay()
      this.stopQuickGo()
      this.isBacking = true
      this.quickNavigationCache = {}
      this.quickNavigationQueue = []
      this.quickSpeed = 50
      this.scheduleLastQuickPage()
    },

    stopQuickBack() {
      this.isBacking = false
      if (this.backTimer) clearTimeout(this.backTimer)
    },

    scheduleLastQuickPage() {
      if (!this.isBacking) return
      if (this.backTimer) clearTimeout(this.backTimer)
      this.backTimer = setTimeout(() => { if (this.isBacking) this.lastQuickPage() }, this.quickSpeed)
    },

    async lastQuickPage() {
      let special = this.checkSpecialJump(this.readProgress, 'back')
      if (special != null) {
        if (special !== this.readProgress) this.readProgress = special
        await this.saveOnBlockTransition(this.readProgress)
        await this.loadQuickPage(this.readProgress)
        this.scheduleLastQuickPage(); return
      }
      if (this.readProgress > 1) {
        this.readProgress--
        await this.saveOnBlockTransition(this.readProgress)
        await this.loadQuickPage(this.readProgress)
        this.scheduleLastQuickPage()
      } else {
        this.stopQuickBack()
      }
    },

    async loadQuickPage(id) {
      if (this.isLoadingScript) return
      this.isLoadingScript = true
      try {
        if (this.quickNavigationCache[id]) {
          this.applyQuickPageScript(this.quickNavigationCache[id], id)
          this.isLoadingScript = false; return
        }
        let end = this.checkEndPage(id)
        if (end) { this.triggerEndSequence(end); this.isLoadingScript = false; return }
        if (!this.gameEngine || !this.isGameEngineLoaded) {
          this.gameEngine = new GameScriptLoader()
          let loaded = await this.gameEngine.loadGameScript()
          this.isGameEngineLoaded = loaded
          if (!loaded) { this.displayText = '脚本加载失败，请重新启动应用'; this.isLoadingScript = false; return }
        }
        let script = await this.gameEngine.getScript(id)
        if (script) {
          this.cachePageScript(id, script)
          this.applyQuickPageScript(script, id)
        } else {
          this.contect = '加载失败，请检查脚本文件'
          this.displayText = this.contect
        }
      } catch (e) {
        this.contect = '加载页面失败'
        this.displayText = this.contect
      } finally {
        this.isLoadingScript = false
      }
    },

    cachePageScript(id, script) {
      if (Object.keys(this.quickNavigationCache).length >= this.quickCacheSize) {
        let oldest = this.quickNavigationQueue.shift()
        if (oldest) delete this.quickNavigationCache[oldest]
      }
      this.quickNavigationCache[id] = script
      let idx = this.quickNavigationQueue.indexOf(id)
      if (idx > -1) this.quickNavigationQueue.splice(idx, 1)
      this.quickNavigationQueue.push(id)
    },

    applyQuickPageScript(script, id) {
      let charScale = this.getCharacterScaleClass(script.z)
      let bgScale = this.getBackgroundScaleClass(script.z)
      this.updateImageIfNeeded('currentBackground', script.background || '', 'background')
      this.currentBackgroundScaleClass = bgScale
      this.updateImageIfNeeded('cgimg', script.cg || '', 'cg')
      this.updateImageIfNeeded('characterimg', script.character || '', 'character')
      this.currentCharacterScaleClass = charScale
      this.character = script.speaker || ''
      let parsed = this.parseTextFontSize(script.text || '')
      this.contect = parsed.text
      this.currentTextFontSize = parsed.fontSize
      this.setChoiceData(script, id)
      this.isPageRead(id).then(r => this.viewed = r).catch(() => this.viewed = false)
      this.displayCharacter = this.character
      this.displayText = this.contect
      this.isTyping = false
      this.currentPageId = id
      if (this.choose) {
        this.stopQuickGo()
        this.stopQuickBack()
      }
    },

    async choose1c() {
      await this.markPageAsRead(this.readProgress)
      this.recordChoice(this.readProgress, 1)
      this.setChooseColors(this.readProgress)
      this.readProgress = this.choose1To
      await this.saveOnBlockTransition(this.readProgress)
      this.loadPage(this.readProgress)
    },
    async choose2c() {
      await this.markPageAsRead(this.readProgress)
      this.recordChoice(this.readProgress, 2)
      this.setChooseColors(this.readProgress)
      this.readProgress = this.choose2To
      await this.saveOnBlockTransition(this.readProgress)
      this.loadPage(this.readProgress)
    },
    async choose3c() {
      await this.markPageAsRead(this.readProgress)
      this.recordChoice(this.readProgress, 3)
      this.setChooseColors(this.readProgress)
      this.readProgress = this.choose3To
      await this.saveOnBlockTransition(this.readProgress)
      this.loadPage(this.readProgress)
    },
    async choose4c() {
      await this.markPageAsRead(this.readProgress)
      this.recordChoice(this.readProgress, 4)
      this.setChooseColors(this.readProgress)
      this.readProgress = this.choose4To
      await this.saveOnBlockTransition(this.readProgress)
      this.loadPage(this.readProgress)
    },
    async choose5c() {
      await this.markPageAsRead(this.readProgress)
      this.recordChoice(this.readProgress, 5)
      this.setChooseColors(this.readProgress)
      this.readProgress = this.choose5To
      await this.saveOnBlockTransition(this.readProgress)
      this.loadPage(this.readProgress)
    },

    autoplay() {
      if (this.isAutoing) this.stopAutoplay()
      else this.startAutoplay()
      this.contrlcenterShow = false
    },

    startAutoplay() {
      this.stopQuickGo()
      this.stopQuickBack()
      this.isAutoing = true
      if (!this.isTyping) this.scheduleNextPage()
    },

    stopAutoplay() {
      this.isAutoing = false
      if (this.autoPlayTimer) clearTimeout(this.autoPlayTimer)
    },

    scheduleNextPage() {
      if (!this.isAutoing) return
      if (this.autoPlayTimer) clearTimeout(this.autoPlayTimer)
      this.autoPlayTimer = setTimeout(() => { if (this.isAutoing) this.nextPage() }, this.autoPlayDelay)
    },

    onInit() {
      this.gameEngine = new GameScriptLoader()
      this.updateTime()
      this.timeTimer = setInterval(() => this.updateTime(), 500)
      setInterval(() => {
        if (this.imageMemoryUsage > this.maxImageMemory * 0.7) this.cleanupImagesByPriority(2)
      }, 5000)
      this.currentBackgroundScaleClass = 'bg-scale-1'
      this.currentCharacterScaleClass = 'character-scale-1'
      this.startSplashCountdown()
    },

    onHide() {
      this.stopAutoplay()
      this.stopQuickGo()
      this.stopQuickBack()
      this.stopBgScroll()
      this.stopCgScroll()
      if (this.typewriterTimer) clearTimeout(this.typewriterTimer)
      if (this.animationTimer) clearTimeout(this.animationTimer)
      if (this.progressSaveTimer) clearTimeout(this.progressSaveTimer)
      if (this.splashTimer) { clearInterval(this.splashTimer); this.splashTimer = null }
      this.cleanupFlashbang()
      if (this.readProgress && this.readProgress > 0) {
        try { storage.set({ key: 'readProgress', value: this.readProgress.toString() }) } catch (e) {}
      }
      if (Object.keys(this.pendingSaves).length > 0) this.savePendingBlocks()
      if (this.gameEngine && this.isGameEngineLoaded) {
        try { storage.set({ key: 'branchChoices', value: JSON.stringify(this.branchConfig.choices || {}) }) } catch (e) {}
      }
      this.cleanupImagesByPriority(3)
    },

    onDestroy() {
      if (this.typewriterTimer) clearTimeout(this.typewriterTimer)
      if (this.autoPlayTimer) clearTimeout(this.autoPlayTimer)
      if (this.timeTimer) clearInterval(this.timeTimer)
      if (this.goTimer) clearTimeout(this.goTimer)
      if (this.backTimer) clearTimeout(this.backTimer)
      if (this.animationTimer) clearTimeout(this.animationTimer)
      if (this.progressSaveTimer) clearTimeout(this.progressSaveTimer)
      if (this.splashTimer) { clearInterval(this.splashTimer); this.splashTimer = null }
      this.stopBgScroll()
      this.stopCgScroll()
      this.cleanupFlashbang()
      if (Object.keys(this.pendingSaves).length > 0) this.savePendingBlocks()
      this.readBlocks = {}
      this.currentBlockIndex = 0
      this.pendingSaves = {}
      this.quickNavigationCache = {}
      this.quickNavigationQueue = []
      this.imageCache = {}
      this.currentImageKeys = []
      this.imageMemoryUsage = 0
      this.lowMemoryMode = false
      this.fontParseCache = {}
      this.fontParseCacheOrder = []
      if (this.gameEngine) this.gameEngine.clearAll()
    },

    async onShow() {
      try {
        await this.loadAllSettings()
        await this.loadReadPages()
        await this.loadChoiceRecords()
        let progress = await this.getReadProgress()
        this.readProgress = progress
        this.currentPageId = progress
        this.lastSavedProgress = progress
        await this.loadSaveSlots()
        if (!this.gameEngine) this.gameEngine = new GameScriptLoader()
        if (!this.isGameEngineLoaded) {
          let loaded = await this.gameEngine.loadGameScript()
          this.isGameEngineLoaded = loaded
          if (!loaded) this.displayText = '脚本加载失败'
        }
        if (this.isGameEngineLoaded) this.loadPage(this.readProgress)
        this.viewed = await this.isPageRead(this.readProgress)
      } catch (e) {
        console.error('onShow执行出错:', e)
      }
      this.setKeepScreenOn(this.screenAlwaysOn)
    },

    async loadAllSettings() {
      return new Promise((resolve) => {
        let settings = SETTINGS_CONFIG
        let count = 0
        settings.forEach(({ key, prop, type }) => {
          storage.get({
            key: key,
            success: (data) => {
              if (data != null) {
                if (type === 'number') this[prop] = Number(data)
                else if (type === 'boolean') this[prop] = data === 'true'
                else this[prop] = data
              }
              if (++count === settings.length) resolve()
            },
            fail: () => { if (++count === settings.length) resolve() }
          })
        })
      })
    },

    async loadSaveSlots() {
      try {
        let slots = await new Promise((resolve) => {
          storage.get({
            key: 'saveSlots',
            success: (data) => { try { resolve(JSON.parse(data)) } catch (e) { resolve(null) } },
            fail: () => resolve(null)
          })
        })
        if (slots && Array.isArray(slots)) this.saveSlots = slots
        let promises = []
        for (let i = 0; i < this.saveSlots.length; i++) {
          promises.push(new Promise((resolve) => {
            storage.get({
              key: `p${i + 1}`,
              success: (data) => {
                let progress = Number(data) || 1
                this.saveSlots[i].progress = progress
                this.saveSlots[i].text = progress === 1 ? '空' : `进度${progress}`
                resolve(true)
              },
              fail: () => {
                this.saveSlots[i].progress = 1
                this.saveSlots[i].text = '空'
                resolve(false)
              }
            })
          }))
        }
        await Promise.all(promises)
      } catch (e) {
        console.error('加载存档时出错:', e)
      }
    },

    saveSlotsConfig() {
      let data = this.saveSlots.map(s => ({ id: s.id, text: s.text, progress: s.progress }))
      storage.set({ key: 'saveSlots', value: JSON.stringify(data) })
    },

    addSaveSlot() {
      if (this.saveSlots.length >= this.maxSaveSlots) {
        prompt.showToast({ message: `已达到最大存档位数量(${this.maxSaveSlots})`, duration: 2000 }); return
      }
      let id = this.saveSlots.length + 1
      this.saveSlots.push({ id: id, text: '空', progress: 1 })
      this.saveSlotsConfig()
      prompt.showToast({ message: `已添加存档位${id}`, duration: 2000 })
    },

    saveToSlot(slot) {
      if (slot > this.saveSlots.length) {
        prompt.showToast({ message: '存档位不存在', duration: 2000 }); return
      }
      let item = this.saveSlots[slot - 1]
      storage.set({
        key: `p${slot}`,
        value: this.readProgress.toString(),
        success: () => {
          item.progress = this.readProgress
          item.text = `进度${this.readProgress}`
          this.saveSlots = [...this.saveSlots]
          prompt.showToast({ message: '保存成功', duration: 2000 })
        },
        fail: () => prompt.showToast({ message: '保存失败', duration: 2000 })
      })
    },

    async deleteSlot(slot) {
      if (slot <= 0 || slot > this.saveSlots.length) {
        prompt.showToast({ message: '存档位不存在', duration: 1000 }); return
      }
      let totalSlots = this.saveSlots.length
      let allData = {}
      for (let i = 1; i <= totalSlots; i++) {
        allData[i] = await new Promise((resolve) => storage.get({ key: `p${i}`, success: resolve, fail: () => resolve(null) }))
      }
      for (let i = 1; i <= totalSlots; i++) {
        await new Promise((resolve) => storage.delete({ key: `p${i}`, success: resolve, fail: resolve }))
      }
      let newIdx = 1
      for (let i = 1; i <= totalSlots; i++) {
        if (i !== slot && allData[i]) {
          await new Promise((resolve) => storage.set({ key: `p${newIdx}`, value: allData[i], success: resolve, fail: resolve }))
          newIdx++
        }
      }
      this.saveSlots.splice(slot - 1, 1)
      for (let i = 0; i < this.saveSlots.length; i++) {
        let id = i + 1
        this.saveSlots[i].id = id
        await new Promise((resolve) => {
          storage.get({
            key: `p${id}`,
            success: (data) => {
              if (data) { let p = Number(data); this.saveSlots[i].progress = p; this.saveSlots[i].text = `进度${p}` }
              else { this.saveSlots[i].progress = 1; this.saveSlots[i].text = '空' }
              resolve()
            },
            fail: () => { this.saveSlots[i].progress = 1; this.saveSlots[i].text = '空'; resolve() }
          })
        })
      }
      this.saveSlots = [...this.saveSlots]
      this.saveSlotsConfig()
      prompt.showToast({ message: `存档位${slot}已删除`, duration: 1500 })
    },

    async reloadAllSaveSlots() {
      let promises = []
      for (let i = 0; i < this.saveSlots.length; i++) {
        let p = new Promise((resolve) => {
          let id = i + 1
          storage.get({
            key: `p${id}`,
            success: (data) => {
              if (data) { let p = Number(data); this.saveSlots[i].progress = p; this.saveSlots[i].text = `进度${p}` }
              else { this.saveSlots[i].progress = 1; this.saveSlots[i].text = '空' }
              resolve(true)
            },
            fail: () => { this.saveSlots[i].progress = 1; this.saveSlots[i].text = '空'; resolve(true) }
          })
        })
        promises.push(p)
      }
      await Promise.all(promises)
      this.saveSlots = [...this.saveSlots]
      return true
    },

    quickSave() {
      this.saveToSlot(1)
      this.contrlcenterShow = false
    },

    loadSlot(slot) {
      this.pageloading()
      storage.get({
        key: `p${slot}`,
        success: async (data) => {
          let progress = Number(data) || 1
          await this.handleBlockChange(progress)
          this.readProgress = progress
          this.loadPage(this.readProgress)
          this.loadShow = false
          this.contrlcenterShow = false
          this.stopAutoplay()
          this.stopQuickGo()
          this.stopQuickBack()
        },
        fail: () => prompt.showToast({ message: '加载失败', duration: 2000 })
      })
    },

    loadStart(slot) {
      this.loadSlot(slot)
      this.contrlcenterShow = false
    },

    async handleBlockChange(newProgress) {
      let newBlock = this.getBlockIndex(newProgress)
      if (newBlock !== this.currentBlockIndex) {
        if (Object.keys(this.pendingSaves).length > 0) await this.savePendingBlocks()
        await this.loadBlock(newBlock)
        this.currentBlockIndex = newBlock
        this.preloadAdjacentBlocks(newProgress)
        this.smartCleanBlocks(newProgress)
      }
    },

    saveProgressToStorage() {
      if (this.readProgress !== this.lastSavedProgress) {
        this.lastSavedProgress = this.readProgress
        storage.set({ key: 'readProgress', value: this.readProgress.toString() })
      }
    },

    async loadPage(id) {
      if (this.isLoadingScript) return
      this.isLoadingScript = true
      try {
        this.checkEndPage(id)
        if (!this.gameEngine || !this.isGameEngineLoaded) {
          this.gameEngine = new GameScriptLoader()
          let loaded = await this.gameEngine.loadGameScript()
          this.isGameEngineLoaded = loaded
          if (!loaded) { this.displayText = '脚本加载失败，请重新启动应用'; this.isLoadingScript = false; return }
        }
        let script = await this.gameEngine.getScript(id)
        if (!script) {
          this.contect = '加载失败，请检查脚本文件'
          this.displayText = this.contect
          this.displayCharacter = '系统'
          this.isLoadingScript = false; return
        }
        let charScale = this.getCharacterScaleClass(script.z)
        let bgScale = this.getBackgroundScaleClass(script.z)
        let bg = script.background || ''
        let speaker = script.speaker || ''
        let text = script.text || ''
        let cg = script.cg || ''
        let charImg = script.character || ''
        await this.smartPreloadImages(script, id)
        if (bg) { this.addToImageCache(bg, 'background'); this.markImageAsUsed(bg, 'background') }
        if (cg) { this.addToImageCache(cg, 'cg'); this.markImageAsUsed(cg, 'cg') }
        if (charImg) { this.addToImageCache(charImg, 'character'); this.markImageAsUsed(charImg, 'character') }
        let parsed = this.parseTextFontSize(text)
        let displayText = parsed.text
        let fontSize = parsed.fontSize
        let bgChanged = bg && bg !== this.currentBackground
        if (bgChanged) {
          this.startBackgroundAnimation(bg, cg, charImg, speaker, displayText, id, charScale, bgScale, fontSize)
          this.setChoiceData(script, id)
          this.currentPageId = id
          if (this.flashbangPages.includes(id)) {
            this.waitForFlashbang = true
            this.displayCharacter = ''
            this.displayText = ''
          }
        } else {
          this.updateImageIfNeeded('currentBackground', bg, 'background')
          this.currentBackgroundScaleClass = bgScale
          this.updateImageIfNeeded('cgimg', cg, 'cg')
          this.updateImageIfNeeded('characterimg', charImg, 'character')
          this.currentCharacterScaleClass = charScale
          this.character = speaker
          this.contect = displayText
          this.currentTextFontSize = fontSize
          this.setChoiceData(script, id)
          this.displayCharacter = this.character
          this.isPageRead(id).then(r => this.viewed = r).catch(() => this.viewed = false)
          this.currentPageId = id
          if (this.flashbangPages.includes(id)) {
            this.waitForFlashbang = true
            this.displayCharacter = ''
            this.displayText = ''
          } else {
            this.startTypewriter()
          }
        }
        if (!this.isEnding && this.flashbangPages.includes(id)) {
          setTimeout(() => { this.triggerFlashbang() }, bgChanged ? 650 : 80)
        }
      } catch (e) {
        console.error('加载页面失败:', e)
        this.contect = '加载页面失败，请稍后重试'
        this.displayText = this.contect
        this.displayCharacter = '系统'
      } finally {
        this.isLoadingScript = false
      }
    },

    setChoiceData(script, id) {
      this.choose = script.choose || false
      this.choose1 = script.choose1 || ''
      this.choose2 = script.choose2 || ''
      this.choose3 = script.choose3 || ''
      this.choose4 = script.choose4 || ''
      this.choose5 = script.choose5 || ''
      this.choose1To = script.choose1To || id
      this.choose2To = script.choose2To || id
      this.choose3To = script.choose3To || id
      this.choose4To = script.choose4To || id
      this.choose5To = script.choose5To || id
      this.choose1Visible = !!(this.choose1 || '').toString().trim()
      this.choose2Visible = !!(this.choose2 || '').toString().trim()
      this.choose3Visible = !!(this.choose3 || '').toString().trim()
      this.choose4Visible = !!(this.choose4 || '').toString().trim()
      this.choose5Visible = !!(this.choose5 || '').toString().trim()
      this.choose = !!(this.choose && (this.choose1Visible || this.choose2Visible || this.choose3Visible || this.choose4Visible || this.choose5Visible))
      if (this.choose) this.setChooseColors(id)
    },

    startTypewriter() {
      if (this.typewriterTimer) clearInterval(this.typewriterTimer)
      this.displayText = ''
      this.currentTextIndex = 0
      this.isTyping = true
      this.typewriterTimer = setInterval(() => {
        if (this.currentTextIndex < this.contect.length) {
          this.displayText += this.contect.charAt(this.currentTextIndex)
          this.currentTextIndex++
          if (this.currentTextIndex % 20 === 0 || this.currentTextIndex === this.contect.length) {
            let now = Date.now()
            if (now - this.lastScrollTime > this.scrollThrottleDelay) {
              this.$element('Scroll').scrollTo({ top: 9999, behavior: 'smooth' })
              this.lastScrollTime = now
            }
          }
        } else {
          this.isTyping = false
          clearInterval(this.typewriterTimer)
          let now = Date.now()
          if (now - this.lastScrollTime > this.scrollThrottleDelay) {
            this.$element('Scroll').scrollTo({ top: 9999, behavior: 'smooth' })
            this.lastScrollTime = now
          }
          if (this.isAutoing) this.scheduleNextPage()
        }
      }, this.textSpeed)
    },

    skipTyping() {
      if (this.skipOnlyRead) {
        this.isPageRead(this.readProgress).then((read) => {
          if (read) this.completeSkipTyping()
        }).catch(() => this.completeSkipTyping())
      } else {
        this.completeSkipTyping()
      }
    },

    completeSkipTyping() {
      if (this.typewriterTimer) clearInterval(this.typewriterTimer)
      this.displayText = this.contect
      this.isTyping = false
      let now = Date.now()
      if (now - this.lastScrollTime > this.scrollThrottleDelay) {
        this.$element('Scroll').scrollTo({ top: 9999, behavior: 'smooth' })
        this.lastScrollTime = now
      }
    },

    triggerEndSequence(endText) {
      this.stopAutoplay()
      this.stopQuickGo()
      this.stopQuickBack()
      if (this.typewriterTimer) clearInterval(this.typewriterTimer)
      this.isTyping = false
      this.isEnding = true
      this.endText = endText
      this.endAnimationDone = false
      this.choose = false
      this.hideText = true
      this.pageShow = true
      this.startBackgroundAnimation('/common/bcgi/画面_白.jpg', '', '', '', '', null, '', 'bg-scale-1', this.fontSize)
    },

    endClickReturn() {
      this.indexRoute()
    },

    playPage() {
      if (this.isEnding && this.endAnimationDone) return
      if (this.isFlashActive) return
      if (this.pageShow === false) this.pageShow = !this.pageShow
    },

    async nextPage() {
      if (this.isTyping || this.isAnimating || this.isGoing || this.isBacking || this.isLoadingScript || this.isFlashActive) return
      if (this.choose === true) { this.stopAutoplay(); return }
      let end = this.checkEndPage(this.readProgress)
      if (end) { this.triggerEndSequence(end); return }
      if (this.branchConfig.hiddenPages[this.readProgress]) {
        let fn = this.branchConfig.hiddenPages[this.readProgress]
        let hidden = fn(this.branchConfig.choices)
        if (hidden !== this.readProgress) {
          await this.markPageAsRead(this.readProgress)
          this.readProgress = hidden
          await this.saveOnBlockTransition(this.readProgress)
          this.loadPage(this.readProgress); return
        }
      }
      await this.markPageAsRead(this.readProgress)
      let special = this.checkSpecialJump(this.readProgress, 'next')
      if (special != null) {
        this.readProgress = special
        await this.saveOnBlockTransition(this.readProgress)
        this.loadPage(this.readProgress); return
      }
      if (!this.choose) {
        this.readProgress++
        await this.saveOnBlockTransition(this.readProgress)
        this.loadPage(this.readProgress)
      }
    },

    displayPage() {
      if (this.isAnimating || this.isAutoing || this.isGoing || this.isBacking || this.contrlcenterShow || this.isEnding || this.isFlashActive) return
      this.pageShow = !this.pageShow
    },

    settingsRoute() {
      this.contrlcenterShow = false
      this.pageloading()
      this.stopAutoplay()
      this.stopQuickGo()
      this.stopQuickBack()
      router.push({ uri: 'pages/settings' })
    },

    lctRoute() {
      this.contrlcenterShow = false
      this.pageloading()
      this.stopAutoplay()
      this.stopQuickGo()
      this.stopQuickBack()
      router.push({ uri: 'pages/lct' })
    },

    indexRoute() {
      router.replace({ uri: 'pages/index' })
    },

    pageloading() {
      this.currentBackground = '/common/bcgi/神社_境内a.jpg'
      this.currentBackgroundScaleClass = 'bg-scale-1'
      this.characterimg = ''
      this.cgimg = ''
      this.currentCharacterScaleClass = 'character-scale-1'
      this.displayText = '......加载中......'
      this.displayCharacter = ' '
      this.currentTextFontSize = this.fontSize
    },

    toTop() {
      this.$element('Scroll').scrollTo({ top: 0, left: 0, behavior: 'smooth' })
    },

    hidecontrlcenter() {
      this.contrlcenterShow = false
    },

    pageSwipe(e) {
      if (this.isEnding || this.isFlashActive) return
      if (e.direction === 'right' && this.readProgress > 1 && this.contrlcenterShow === false && this.pageShow === true && !this.isAnimating) {
        let special = this.checkSpecialJump(this.readProgress, 'back')
        if (special != null) {
          if (special !== this.readProgress) this.readProgress = special
        } else {
          this.readProgress--
        }
        this.loadPage(this.readProgress)
      } else if (e.direction === 'down' && !this.isAnimating) {
        this.contrlcenterShow = true
        this.saveProgressToStorage()
        this.savePendingBlocks()
      } else if (e.direction === 'up' && !this.isAnimating) {
        this.contrlcenterShow = false
      }
    },

    loadSaveSwipe(e) {
      if (e.direction === 'right') {
        if (this.loadShow) this.loadconShow()
        else if (this.saveShow) this.saveconShow()
      }
    },

    controlCenterSwipe(e) {
      if (e.direction === 'right') this.hidecontrlcenter()
    },

    loadconShow() {
      this.loadShow = !this.loadShow
      if (this.loadShow) {
        this.stopAutoplay()
        this.stopQuickGo()
        this.stopQuickBack()
      }
    },

    saveconShow() {
      this.saveShow = !this.saveShow
      if (this.saveShow) {
        this.stopAutoplay()
        this.stopQuickGo()
        this.stopQuickBack()
      }
    },

    async loadChoiceRecords() {
      return new Promise((resolve) => {
        storage.get({
          key: 'branchChoices',
          success: (data) => {
            try { this.branchConfig.choices = JSON.parse(data) } catch (e) { this.branchConfig.choices = {} }
            resolve()
          },
          fail: () => { this.branchConfig.choices = {}; resolve() }
        })
      })
    },

    setChooseColors(id) {
      let choice = this.branchConfig.choices[id]
      this.choose1Color = choice === 1 ? this.readColor : this.unreadColor
      this.choose2Color = choice === 2 ? this.readColor : this.unreadColor
      this.choose3Color = choice === 3 ? this.readColor : this.unreadColor
      this.choose4Color = choice === 4 ? this.readColor : this.unreadColor
      this.choose5Color = choice === 5 ? this.readColor : this.unreadColor
    },

    getReadProgress() {
      return new Promise((resolve) => {
        storage.get({
          key: 'readProgress',
          success: (data) => resolve(Number(data) || 1),
          fail: () => resolve(1)
        })
      })
    }
  }
</script>
