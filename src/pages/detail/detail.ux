<template>
  <div class="page" onswipe="pageSwipe" onlongpress="displayPage" onclick="playPage">
    <scroll id="bgScroll" class="bg-scroll" scroll-x="true" scroll-y="{{false}}" bounces="false">
      <div class="bg-content">
        <image class="backgroundimg {{currentBackgroundScaleClass}}" src="{{currentBackground}}" onerror="onImageError('background', currentBackground, $event)"></image>
        <block if="{{showNextBackground}}">
          <image class="backgroundimg next-background {{nextBackgroundScaleClass}}" src="{{nextBackground}}" onerror="onImageError('nextBackground', nextBackground, $event)"></image>
        </block>
        <block if="{{characterimg}}">
          <div class="character-container">
            <image class="characterimg {{currentCharacterScaleClass}}" src="{{characterimg}}" onerror="onImageError('character', characterimg, $event)"></image>
          </div>
        </block>
        <block if="{{nextCharacterImg && showNextCharacter}}">
          <div class="character-container">
            <image class="characterimg next-character {{nextCharacterScaleClass}}" src="{{nextCharacterImg}}" onerror="onImageError('nextCharacter', nextCharacterImg, $event)"></image>
          </div>
        </block>
      </div>
    </scroll>
    <block if="{{cgimg || showNextCg}}">
      <scroll id="cgScroll" class="cg-scroll" scroll-x="true" scroll-y="{{false}}" bounces="false">
        <div class="cg-content" style="width: {{cgContentWidth}}px;">
          <block if="{{cgimg}}">
            <image class="cg-image" style="width: {{cgContentWidth}}px; object-fit: {{cgObjectFit}};" src="{{cgimg}}" onerror="onImageError('cg', cgimg, $event)"></image>
          </block>
          <block if="{{showNextCg}}">
            <image class="cg-image next-cg" style="width: {{cgContentWidth}}px; object-fit: {{cgObjectFit}};" src="{{nextCg}}" onerror="onImageError('nextCg', nextCg, $event)"></image>
          </block>
        </div>
      </scroll>
    </block>
    <block if="{{pageShow && !hideText && !isEnding}}">
      <image class="board" src="/pages/detail/board.png" onclick="nextPage"></image>
    </block>
    <block if="{{pageShow && !hideText && !isEnding}}">
      <text class="character" style="color: {{viewed ? readColor : unreadColor}}; font-weight: {{boldText ? 'bold' : 'normal'}}; font-size: {{characterNameFontSize}}px; height: {{characterNameFontSize + 10}}px;">{{displayCharacter}}</text>
    </block>
    <block if="{{!isEnding}}">
      <scroll id="Scroll" class="scroll2" style="top: {{300 + characterNameFontSize + 14}}px;" scroll-y="{{true}}" onclick="nextPage" bounces="true">
        <block if="{{pageShow && !hideText}}">
          <text class="contect" style="color: {{viewed ? readColor : unreadColor}}; font-size: {{currentTextFontSize}}px; font-weight: {{boldText ? 'bold' : 'normal'}};">{{displayText}}</text>
        </block>
      </scroll>
    </block>
    <block if="{{isAnimating}}">
      <div class="background-mask" style="background-color: {{maskColor}};"></div>
    </block>
    <block if="{{showFlashbang}}">
      <div class="flashbang-mask" onclick="nextPage" style="opacity: {{flashbangOpacity}};"></div>
    </block>
    <block if="{{isAutoing && !contrlcenterShow && !isAnimating && !isEnding}}">
      <div class="skip-btn2" onclick="stopAutoplay">
        <text>停止自动播放</text>
      </div>
    </block>
    <block if="{{isGoing && !contrlcenterShow && !isAnimating && !isEnding}}">
      <div class="skip-btn3" onclick="stopQuickGo">
        <text>停止快进</text>
      </div>
    </block>
    <block if="{{isBacking && !contrlcenterShow && !isAnimating && !isEnding}}">
      <div class="skip-btn4" onclick="stopQuickBack">
        <text>停止快退</text>
      </div>
    </block>
    <block if="{{choose && pageShow && !isAnimating && !isEnding}}">
      <div class="choose">
        <block if="{{choose1Visible}}">
          <text class="choosetext" onclick="choose1c" style="color: {{choose1Color}};">{{choose1}}</text>
        </block>
        <block if="{{choose2Visible}}">
          <text class="choosetext" onclick="choose2c" style="color: {{choose2Color}};">{{choose2}}</text>
        </block>
        <block if="{{choose3Visible}}">
          <text class="choosetext" onclick="choose3c" style="color: {{choose3Color}};">{{choose3}}</text>
        </block>
        <block if="{{choose4Visible}}">
          <text class="choosetext" onclick="choose4c" style="color: {{choose4Color}};">{{choose4}}</text>
        </block>
        <block if="{{choose5Visible}}">
          <text class="choosetext" onclick="choose5c" style="color: {{choose5Color}};">{{choose5}}</text>
        </block>
      </div>
    </block>
    <block if="{{contrlcenterShow && !isAnimating && !isEnding}}">
      <div class="page1" onswipe="controlCenterSwipe">
        <scroll id="mainScroll" class="scroll" scroll-y="{{true}}" bounces="true">
          <text class="load2">{{nowTime}} | {{readProgress}}</text>
          <text class="load" onclick="hidecontrlcenter">返回</text>
          <text class="load" onclick="saveconShow">保存</text>
          <text class="load" onclick="loadconShow">加载</text>
          <text class="load" onclick="quickSave">快速存档</text>
          <text class="load" onclick="loadStart(1)">快速读档</text>
          <text class="load" onclick="indexRoute">返回主页</text>
          <text class="load" onclick="settingsRoute">设置</text>
          <text class="load" onclick="lctRoute">流程图</text>
          <block if="{{!isBacking && !isGoing}}">
            <text class="load" onclick="autoplay">{{isAutoing ? '停止自动播放' : '自动播放'}}</text>
          </block>
          <block if="{{!isBacking && !isAutoing}}">
            <text class="load" onclick="quickgo">{{isGoing ? '停止快进' : '快进'}}</text>
          </block>
          <block if="{{!isAutoing && !isGoing}}">
            <text class="load" onclick="quickback">{{isBacking ? '停止快退' : '快退'}}</text>
          </block>
          <text class="load2"></text>
        </scroll>
      </div>
    </block>
    <block if="{{loadShow && !isAnimating && !isEnding}}">
      <div class="page1" onswipe="loadSaveSwipe">
        <text class="load3">点击跳转至对应页面</text>
        <scroll id="loadScroll" class="scroll" scroll-y="{{true}}" bounces="true">
          <block for="{{item in saveSlots}}" tid="index">
            <div class="save-item" onclick="loadSlot(index + 1)">
              <text class="load">存档{{index + 1}}: {{item.text}}</text>
            </div>
          </block>
          <text class="load2"></text>
        </scroll>
        <div class="back-btn-wrap" onclick="loadconShow">
          <text class="back-btn-text">返回</text>
        </div>
      </div>
    </block>
    <block if="{{saveShow && !isAnimating && !isEnding}}">
      <div class="page1" onswipe="loadSaveSwipe">
        <text class="load3">长按删除存档位</text>
        <scroll id="saveScroll" class="scroll" scroll-y="{{true}}" bounces="true">
          <block for="{{item in saveSlots}}" tid="index">
            <div class="save-item">
              <text class="load" onlongpress="deleteSlot(index + 1)" onclick="saveToSlot(index + 1)">存档{{index + 1}}: {{item.text}}</text>
            </div>
          </block>
          <div class="save-add" onclick="addSaveSlot">
            <text class="load">[ + 添加存档位 ]</text>
          </div>
          <text class="load2"></text>
        </scroll>
        <div class="back-btn-wrap" onclick="saveconShow">
          <text class="back-btn-text">返回</text>
        </div>
      </div>
    </block>
    <block if="{{isEnding && endAnimationDone}}">
      <div class="end-overlay" onclick="endClickReturn">
        <text class="end-text">{{endText}}</text>
      </div>
    </block>
  </div>
</template>

