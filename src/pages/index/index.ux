    z-index: 0;
    flex: 1;
    width: 100%;
  }
  .save-item {
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
</style>

<script>
  import system from '@system.app'
  import storage from '@system.storage'
  import router from '@system.router'
  import prompt from '@system.prompt'

  export default {
    data: {
      uishow: true,
      readProgress: 1,
      saveSlots: [
        { id: 1, text: '空', progress: 1 },
        { id: 2, text: '空', progress: 1 },
        { id: 3, text: '空', progress: 1 },
        { id: 4, text: '空', progress: 1 },
        { id: 5, text: '空', progress: 1 }
      ],
      maxSaveSlots: 100,
      loadShow: false,
      loading: false,
      bgIndex: 0,
      bgList: [
        '/common/title_bg0.jpg',
        '/common/title_bg1.jpg',
        '/common/title_bg2.jpg',
        '/common/title_bg3.jpg',
        '/common/title_bg4.jpg',
        '/common/title_bg5.jpg',
        '/common/title_bg6.jpg',
        '/common/title_bg7.jpg',
        '/common/title_bg8.jpg'
      ],
      bg: '/common/title_bg.jpg',
      firstLaunchChecked: false
    },
    back() {},
    loadingp() {
      this.loading = !this.loading
    },
    hidui() {
      this.uishow = !this.uishow
    },
    async onShow() {
      this.checkFirstLaunch()
      storage.get({
        key: 'bg',
        success: (data) => {
          console.log('读取背景索引成功:', data)
          let index = parseInt(data)
          if (!isNaN(index) && index >= 0 && index < this.bgList.length) {
            this.bgIndex = index
            console.log('使用保存的背景索引:', this.bgIndex)
          } else {
            console.log('背景索引无效，使用默认值0')
            this.bgIndex = 0
          }
          this.updateBackground()
        },
        fail: () => {
          console.log('未找到背景设置，使用默认值')
          this.updateBackground()
        }
      })
      storage.get({
        key: 'readProgress',
        success: (data) => {
          console.log('流动进度读取成功')
          this.readProgress = Number(data) || 1
        },
        fail: (data) => {
          console.log(`流动读取失败,${data}`)
        }
      })
      await this.loadSaveSlots()
    },
    async loadSaveSlots() {
      try {
        let slots = await new Promise((resolve) => {
          storage.get({
            key: 'saveSlots',
            success: (data) => {
              if (data) {
                try {
                  let parsed = JSON.parse(data)
                  resolve(parsed)
                } catch (e) {
                  resolve(null)
                }
              } else {
                resolve(null)
              }
            },
            fail: () => {
              resolve(null)
            }
          })
        })
        if (slots && Array.isArray(slots)) {
          this.saveSlots = slots
        }
        let promises = []
        for (let i = 0; i < this.saveSlots.length; i++) {
          let p = new Promise((resolve) => {
            storage.get({
              key: `p${i + 1}`,
              success: (data) => {
                let progress = Number(data) || 1
                this.saveSlots[i].progress = progress
                this.saveSlots[i].text = progress === 1 ? '空' : `进度${progress}`
                resolve(true)
              },
              fail: (data) => {
                console.log(`存档${i + 1}读取失败:`, data)
                this.saveSlots[i].progress = 1
                this.saveSlots[i].text = '空'
                resolve(false)
              }
            })
          })
          promises.push(p)
        }
        await Promise.all(promises)
        console.log(`加载了${this.saveSlots.length}个存档位`)
      } catch (e) {
        console.error('加载存档时出错:', e)
      }
    },
    reset() {
      this.bgIndex = (this.bgIndex + 1) % this.bgList.length
      this.updateBackground()
      storage.set({
        key: 'bg',
        value: String(this.bgIndex),
        success: () => {
          console.log(`背景索引保存成功: ${this.bgIndex}`)
        },
        fail: (data) => {
          console.error('背景保存失败:', data)
        }
      })
    },
    updateBackground() {
      let index = this.bgIndex % this.bgList.length
      this.bg = this.bgList[index]
    },
    loadSlot(slot) {
      console.log('加载存档:', slot)
      storage.get({
        key: `p${slot}`,
        success: (data) => {
          let progress = Number(data) || 1
          console.log(`从存档${slot}读取进度:`, progress)
          storage.set({
            key: 'readProgress',
            value: progress.toString(),
            success: () => console.log('进度设置成功'),
            fail: (err) => console.error('进度设置失败:', err)
          })
          router.replace({ uri: 'pages/detail' })
          this.loadShow = false
        },
        fail: (data) => {
          console.error(`读取存档${slot}失败:`, data)
          prompt.showToast({ message: '加载失败', duration: 2000 })
        }
      })
    },
    about() {
      router.push({ uri: 'pages/about' })
    },
    settings() {
      router.push({ uri: 'pages/settings' })
    },
    more() {
      router.push({ uri: 'pages/more' })
    },
    die() {
      system.terminate()
    },
    start() {
      this.loadingp()
      storage.set({
        key: 'readProgress',
        value: JSON.stringify(1),
        success: () => console.log('进度重置成功'),
        fail: (err) => console.error('进度重置失败:', err)
      })
      router.replace({ uri: 'pages/detail' })
    },
    lastStart() {
      this.loadingp()
      router.replace({ uri: 'pages/detail' })
    },
    loadProccess() {
      this.loadShow = true
    },
    unloadProccess() {
      this.loadShow = false
    },
    loadpageProccess(e) {
      if (this.loadShow === true && e.direction === 'right') {
        this.loadShow = false
      }
    },
    checkFirstLaunch() {
      if (this.firstLaunchChecked) return
      this.firstLaunchChecked = true
      storage.get({
        key: 'hasLaunchedBefore2',
        success: (data) => {
          if (data !== 'true') {
            storage.set({
              key: 'hasLaunchedBefore2',
              value: 'true',
              success: () => {},
              fail: () => {}
            })
            router.push({ uri: 'pages/about' })
          }
        },
        fail: () => {
          storage.set({
            key: 'hasLaunchedBefore2',
            value: 'true',
            success: () => {},
            fail: () => {}
          })
          router.push({ uri: 'pages/about' })
        }
      })
    }
  }
</script>
