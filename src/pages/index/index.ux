  .page {
    background-color: rgb(248, 248, 255);
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    height: 490px;
    overflow: hidden;
  }
  .about {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
