    margin-bottom: auto;
    margin-left: auto;
  }
  .about {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
    align-items: flex-end;
    top: 15px;
    right: 250px;
    position: absolute;
  }
  .hd {
    position: absolute;
    top: 0;
  }
  .background {
    top: 0px;
    position: absolute;
  }
  .background2 {
    top: 100px;
    position: absolute;
  }
  .reset2 {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
    align-items: flex-end;
    bottom: 15px;
    right: 15px;
    position: absolute;
  }
  .logo {
    top: 95px;
  }
  .settings {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
    align-items: flex-end;
    top: 15px;
    left: 250px;
    position: absolute;
  }
  .reset {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
    align-items: flex-end;
    bottom: 100px;
    right: 15px;
    position: absolute;
  }
  .back {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
    align-items: flex-end;
    bottom: 15px;
    right: 15px;
    position: absolute;
  }
  .group-1 {
    top: 75px;
    flex-direction: column;
    width: 80%;
  }
  .mid {
    margin-bottom: 10px;
    font-size: 35px;
    color: #000000;
    font-weight: 800;
  }
  .bc {
    position: absolute;
    width: 336px;
    height: 480px;
    top: 0;
    left: 0;
    background-color: rgb(116, 69, 47);
    z-index: -1;
  }
  .page1 {
    margin-top: auto;
    position: absolute;
    background-color: rgba(255, 255, 255, 0.88);
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    margin-right: auto;
    margin-bottom: auto;
    margin-left: auto;
    width: 100%;
  }
  .page3 {
    position: absolute;
    background-color: rgba(255, 255, 255, 0.88);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-top: auto;
    margin-right: auto;
    margin-bottom: auto;
