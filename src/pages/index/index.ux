    width: 192px;
    object-fit: cover;
    z-index: 1;
  }
  .settings {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
    align-items: flex-end;
    top: 15px;
    right: 22px;
    position: absolute;
  }
  .back {
    background-color: rgba(255, 255, 255, 0);
    justify-content: flex-start;
    align-items: flex-end;
    bottom: 45px;
    right: 6px;
    position: absolute;
  }
  .group-1 {
    top: 280px;
    flex-direction: column;
    width: 90%;
  }
  .mid {
    margin-bottom: 9px;
    font-size: 24px;
    color: #000000;
    font-weight: 800;
  }
  .page1 {
    position: absolute;
    background-color: #ffffff;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    height: 490px;
    top: 0;
    left: 0;
    z-index: 10;
  }
  .time-bar {
    width: 192px;
    height: 35px;
    justify-content: center;
    align-items: center;
    background-color: rgba(0, 0, 0, 0.05);
    margin-top: 25px;
  }
  .time-text {
    font-size: 18px;
    color: #666666;
    text-align: center;
  }
  .load {
    margin-top: 8px;
    font-size: 24px;
    color: #000000;
    font-weight: 800;
    width: 190px;
    background-color: rgba(226, 216, 120, 0.267);
    text-align: center;
    padding-top: 12px;
    padding-right: 0;
    padding-bottom: 12px;
    padding-left: 0;
    border-radius: 8px;
  }
  .load2 {
    margin-top: 9px;
    font-size: 28px;
    color: #000000;
    font-weight: 800;
    width: 85%;
    text-align: center;
  }
  .scroll {
    height: 405px;
    text-align: left;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    z-index: 0;
    flex: 1;
    width: 100%;
  }
  .scroll-bottom-space {
    height: 60px;
  }
  .save-item {
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
  }
  .back-btn-wrap {
    position: absolute;
    bottom: 0;
    width: 192px;
    height: 50px;
    justify-content: center;
    align-items: center;
    z-index: 20;
    background-color: rgba(255, 255, 255, 0.85);
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-color: #333333;
    border-style: solid;
  }
  .back-btn-text {
    font-size: 26px;
    color: #333333;
    text-align: center;
  }
</style>
