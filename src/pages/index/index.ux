<template>
  <div class="page" onswipe="loadpageProccess">
    <block if="{{uishow}}">
      <image class="background" src="/common/title_bg.jpg"></image>
    </block>
    <block if="{{uishow}}">
      <image class="logo" src="/pages/index/deactivelogo.png"></image>
    </block>
    <block if="{{uishow}}">
      <image class="about" src="/pages/index/info.png" onclick="about"></image>
    </block>
    <block if="{{uishow}}">
      <image class="settings" src="/pages/index/settings.png" onclick="settings"></image>
    </block>
    <div class="group-1">
      <block if="{{uishow}}">
        <text class="mid" onclick="start">开始游戏</text>
      </block>
      <block if="{{uishow}}">
        <text class="mid" onclick="lastStart">从上次开始</text>
      </block>
      <block if="{{uishow}}">
        <text class="mid" onclick="loadProccess">读取存档</text>
      </block>
      <block if="{{uishow}}">
        <text class="mid" onclick="more">更多</text>
      </block>
    </div>
    <block if="{{!uishow}}">
      <image class="bc" src="/common/bcgi/空_夕空.jpg"></image>
    </block>
    <block if="{{!uishow}}">
      <image class="reset2" src="/common/reset.png" onclick="reset"></image>
    </block>
    <block if="{{!uishow}}">
      <image class="background2" src="/common/title_bg.jpg" onclick="hidui"></image>
    </block>
    <block if="{{uishow}}">
      <image class="back" src="/common/go.png" onclick="die"></image>
    </block>
    <block if="{{loadShow}}">
      <div class="page1">
        <text class="load" onclick="unloadProccess">返回</text>
        <scroll id="mainScroll" class="scroll" bounces="true">
          <block for="{{item in saveSlots}}" tid="index">
            <div class="save-item" onclick="loadSlot(index + 1)">
              <text class="load">存档{{index + 1}}: {{item.text}}</text>
            </div>
          </block>
          <text class="load2"></text>
        </scroll>
      </div>
    </block>
  </div>
</template>

<style>
