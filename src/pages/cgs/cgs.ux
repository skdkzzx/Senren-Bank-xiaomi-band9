"/common/cimg/xz08_1.png","/common/cimg/xz08_2.png","/common/cimg/xz08_3.png","/common/cimg/xz09_1.png","/common/cimg/xz09_2.png","/common/cimg/xz09_3.png","/common/cimg/xz10_1.png","/common/cimg/xz10_2.png","/common/cimg/xz10_3.png","/common/cimg/xz11_1.png","/common/cimg/xz11_2.png","/common/cimg/xz11_3.png","/common/cimg/xz12_1.png","/common/cimg/xz12_2.png","/common/cimg/xz12_3.png","/common/cimg/yw01_1.png","/common/cimg/yw01_2.png","/common/cimg/yw01_3.png","/common/cimg/yw02_1.png","/common/cimg/yw02_2.png","/common/cimg/yw02_3.png","/common/cimg/yw03_1.png","/common/cimg/yw03_2.png","/common/cimg/yw03_3.png","/common/cimg/yw04_1.png","/common/cimg/yw04_2.png","/common/cimg/yw04_3.png","/common/cimg/yw05_1.png","/common/cimg/yw05_2.png","/common/cimg/yw05_3.png","/common/cimg/yw06_1.png","/common/cimg/yw06_2.png","/common/cimg/yw06_3.png","/common/cimg/yw07_1.png","/common/cimg/yw07_2.png","/common/cimg/yw07_3.png","/common/cimg/yw08_1.png","/common/cimg/yw08_2.png","/common/cimg/yw08_3.png","/common/cimg/yw09_1.png","/common/cimg/yw09_2.png","/common/cimg/yw09_3.png","/common/cimg/yw10_1.png","/common/cimg/yw10_2.png","/common/cimg/yw10_3.png","/common/cimg/yw11_1.png","/common/cimg/yw11_2.png","/common/cimg/yw11_3.png","/common/cimg/yw12_1.png","/common/cimg/yw12_2.png","/common/cimg/yw12_3.png","/common/cimg/yw13_1.png","/common/cimg/yw13_2.png","/common/cimg/yw13_3.png","/common/cimg/yw14_1.png","/common/cimg/yw14_2.png","/common/cimg/yw14_3.png"
    ],
    charIndex: 0,
    currentChar: '/common/cimg/hz302.png',

    backgroundList: [
      "/common/bcgi/ecall.jpg","/common/bcgi/空_夕空.jpg","/common/bcgi/空_夕_冬.jpg","/common/bcgi/空_夕_夏.jpg","/common/bcgi/空_夕_春.jpg","/common/bcgi/空_夕_秋.jpg","/common/bcgi/空_夜_冬.jpg","/common/bcgi/空_夜_夏.jpg","/common/bcgi/空_夜_春.jpg","/common/bcgi/空_夜_秋.jpg","/common/bcgi/空_昼_冬.jpg","/common/bcgi/空_昼_夏.jpg","/common/bcgi/空_昼_春.jpg","/common/bcgi/空_昼_秋.jpg","/common/bcgi/画面_白.jpg","/common/bcgi/画面_黒.jpg"
    ],
    bgIndex: 0,
    currentBg: '/common/bcgi/空_夕空.jpg',

    cguishow: true,
    lhchshow: true,
    lhuishow: true,
  },

  onInit() {
    this.initImages();
    this.loadSavedIndex();
  },

  loadSavedIndex() {
    const self = this;
    storage.get({
      key: 'cgLastIndex',
      success: function(data) {
        const savedIndex = parseInt(data);
        if (!isNaN(savedIndex) && savedIndex >= 0 && savedIndex < self.cgList.length) {
          self.cgIndex = savedIndex;
          self.currentCG = self.cgList[self.cgIndex];
        }
      }
    });
  },

  saveCGIndex() {
    const self = this;
    storage.set({
      key: 'cgLastIndex',
      value: String(self.cgIndex),
      fail: function(error) {
        console.error('CG索引保存失败:', error);
      }
    });
  },

  initImages() {
    if (this.cgList.length > 0) this.currentCG = this.cgList[0];
    if (this.characterList.length > 0) this.currentChar = this.characterList[0];
    if (this.backgroundList.length > 0) this.currentBg = this.backgroundList[0];
  },

  // ================= 页面切换方法 =================
  hidcgui(){
    this.cguishow = !this.cguishow;
  },
  hidlhch(){
    this.lhchshow = !this.lhchshow;
  },
  hidlhui(){
    this.lhuishow = !this.lhuishow;
  },
  showcg() {
    this.jump = false;
    this.cgshow = true;
    this.lhshow = false;
    if (this.cgList.length > 0 && this.cgIndex < this.cgList.length) {
      this.currentCG = this.cgList[this.cgIndex];
    }
  },

  showlh() {
    this.jump = false;
    this.cgshow = false;
    this.lhshow = true;
    if (this.characterList.length > 0 && this.charIndex < this.characterList.length) {
      this.currentChar = this.characterList[this.charIndex];
    }
    if (this.backgroundList.length > 0 && this.bgIndex < this.backgroundList.length) {
      this.currentBg = this.backgroundList[this.bgIndex];
    }
  },

  // ================= 图片切换方法 =================

  // 通用图片切换方法
  switchImage(listName, indexName, currentName, direction, callback) {
    const list = this[listName];
    if (list.length === 0) return;
    this[indexName] = (this[indexName] + direction + list.length) % list.length;
    this[currentName] = list[this[indexName]];
    if (callback) callback();
  },

  // CG切换
  lastcg() { this.switchImage('cgList', 'cgIndex', 'currentCG', -1, () => this.saveCGIndex()); },
  entercg() { this.switchImage('cgList', 'cgIndex', 'currentCG', 1, () => this.saveCGIndex()); },

  // 立绘切换
  lastlh() { this.switchImage('characterList', 'charIndex', 'currentChar', -1); },
  enterlh() { this.switchImage('characterList', 'charIndex', 'currentChar', 1); },

  // 背景切换
  lastcgb() { this.switchImage('backgroundList', 'bgIndex', 'currentBg', -1); },
  entercgb() { this.switchImage('backgroundList', 'bgIndex', 'currentBg', 1); },

  back() {
    if (this.jump === true) {
      router.back({ uri: 'pages/more' });
    } else {
      this.jump = true;
      this.cgshow = false;
      this.lhshow = false;
    }
  },

  // 长按快速切换相关
  autoSwitchTimer: null,
  autoSwitchStopTimer: null,
  autoSwitchDelay: 300,
  switchDirection: null,

  clickLastCG() {
    this.stopAutoSwitch();
    this.lastcg();
  },
  clickNextCG() {
    this.stopAutoSwitch();
    this.entercg();
  },
  clickLastBg() {
    this.stopAutoSwitch();
    this.lastcgb();
  },
  clickNextBg() {
    this.stopAutoSwitch();
    this.entercgb();
  },
  clickLastChar() {
    this.stopAutoSwitch();
    this.lastlh();
  },
  clickNextChar() {
    this.stopAutoSwitch();
    this.enterlh();
  },
  doAutoSwitch() {
    const self = this;
    if (!self.switchDirection) return;
    if (self.switchDirection === 'last') {
      self.lastcg();
    } else if (self.switchDirection === 'next') {
      self.entercg();
    }
    self.autoSwitchDelay = Math.max(50, self.autoSwitchDelay - 20);
    self.autoSwitchTimer = setTimeout(function() {
      self.doAutoSwitch();
    }, self.autoSwitchDelay);
  },
  startLastCG() {
    this.stopAutoSwitch();
    this.switchDirection = 'last';
    this.autoSwitchDelay = 300;
    this.lastcg();
    this.doAutoSwitch();
    this.autoSwitchStopTimer = setTimeout(function() {
      this.stopAutoSwitch();
    }.bind(this), 3000);
  },
  startNextCG() {
    this.stopAutoSwitch();
    this.switchDirection = 'next';
    this.autoSwitchDelay = 300;
    this.entercg();
    this.doAutoSwitch();
    this.autoSwitchStopTimer = setTimeout(function() {
      this.stopAutoSwitch();
    }.bind(this), 3000);
  },
  startLastBg() {
    this.stopAutoSwitch();
    this.lastcgb();
    this.autoSwitchTimer = setInterval(() => { this.lastcgb(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  startNextBg() {
    this.stopAutoSwitch();
    this.entercgb();
    this.autoSwitchTimer = setInterval(() => { this.entercgb(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  startLastChar() {
    this.stopAutoSwitch();
    this.lastlh();
    this.autoSwitchTimer = setInterval(() => { this.lastlh(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  startNextChar() {
    this.stopAutoSwitch();
    this.enterlh();
    this.autoSwitchTimer = setInterval(() => { this.enterlh(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  stopAutoSwitch() {
    if (this.autoSwitchTimer) {
      clearTimeout(this.autoSwitchTimer);
      this.autoSwitchTimer = null;
    }
    if (this.autoSwitchStopTimer) {
      clearTimeout(this.autoSwitchStopTimer);
      this.autoSwitchStopTimer = null;
    }
    this.autoSwitchDelay = 300;
    this.switchDirection = null;
  }
};
</script>

