      "/common/bcgi/ecall.jpg","/common/bcgi/朝武_リビングa.jpg","/common/bcgi/朝武_リビングb.jpg","/common/bcgi/朝武_リビングc.jpg","/common/bcgi/朝武_リビングd.jpg","/common/bcgi/朝武_芳乃の部屋a.jpg","/common/bcgi/朝武_芳乃の部屋c.jpg","/common/bcgi/朝武_芳乃の部屋d.jpg","/common/bcgi/朝武_芳乃の部屋m.jpg","/common/bcgi/朝武_風呂場a.jpg","/common/bcgi/朝武_風呂場b.jpg","/common/bcgi/朝武_風呂場d.jpg","/common/bcgi/朝武_自室a.jpg","/common/bcgi/朝武_自室b.jpg","/common/bcgi/朝武_自室c.jpg","/common/bcgi/朝武_自室d.jpg","/common/bcgi/朝武_自室m.jpg","/common/bcgi/画面_白.jpg","/common/bcgi/画面_黒.jpg","/common/bcgi/街_お店a.jpg","/common/bcgi/街_お店b.jpg","/common/bcgi/街_お店c.jpg","/common/bcgi/街_雰囲気a.jpg","/common/bcgi/街_雰囲気b.jpg","/common/bcgi/街_雰囲気c.jpg","/common/bcgi/街_甘味処a.jpg","/common/bcgi/街_甘味処b.jpg","/common/bcgi/街_甘味処d.jpg","/common/bcgi/街_目抜き通りa.jpg","/common/bcgi/街_目抜き通りb.jpg","/common/bcgi/街_目抜き通りc.jpg","/common/bcgi/街_通学路a.jpg","/common/bcgi/街_通学路b.jpg","/common/bcgi/街_通学路c.jpg","/common/bcgi/街_小道a.jpg","/common/bcgi/街_小道b.jpg","/common/bcgi/街_小道c.jpg","/common/bcgi/街_診療所a.jpg","/common/bcgi/街_診療所b.jpg","/common/bcgi/街_診療所d.jpg","/common/bcgi/空_青空.jpg","/common/bcgi/空_夕空.jpg","/common/bcgi/空_夜空.jpg","/common/bcgi/旅館_レナの部屋a.jpg","/common/bcgi/旅館_レナの部屋d.jpg","/common/bcgi/旅館_客室a.jpg","/common/bcgi/旅館_客室b.jpg","/common/bcgi/旅館_客室c.jpg","/common/bcgi/旅館_客室d.jpg","/common/bcgi/旅館_廊下a.jpg","/common/bcgi/旅館_廊下d.jpg","/common/bcgi/旅館_旅館前a.jpg","/common/bcgi/旅館_旅館前b.jpg","/common/bcgi/旅館_旅館前c.jpg","/common/bcgi/山_川沿いa.jpg","/common/bcgi/山_川沿いc.jpg","/common/bcgi/山_山の中１a.jpg","/common/bcgi/山_山の中１b.jpg","/common/bcgi/山_山の中１c.jpg","/common/bcgi/山_山の中２a.jpg","/common/bcgi/山_山の中２b.jpg","/common/bcgi/山_山の中２c.jpg","/common/bcgi/山_山道a.jpg","/common/bcgi/山_山道b.jpg","/common/bcgi/山_山道c.jpg","/common/bcgi/神社_境内a.jpg","/common/bcgi/神社_境内b.jpg","/common/bcgi/神社_境内c.jpg","/common/bcgi/神社_神社内a.jpg","/common/bcgi/神社_神社内b.jpg","/common/bcgi/神社_神社内d.jpg","/common/bcgi/特殊_武家屋敷a.jpg","/common/bcgi/特殊_武家屋敷d.jpg","/common/bcgi/学院_教室a.jpg","/common/bcgi/学院_教室b.jpg","/common/bcgi/学院_教室授業a.jpg","/common/bcgi/学院_教室休憩a.jpg","/common/bcgi/学院_廊下a.jpg","/common/bcgi/学院_学院前a.jpg"
    ],
    bgIndex: 0,
    currentBg: '/common/bcgi/空_夕空.jpg',

    cguishow: true,
    lhchshow: true,
    lhuishow: true,
  },

  onInit() {
    this.initImages();
    this.loadSavedIndex();
  },

  loadSavedIndex() {
    const self = this;
    storage.get({
      key: 'cgLastIndex',
      success: function(data) {
        const savedIndex = parseInt(data);
        if (!isNaN(savedIndex) && savedIndex >= 0 && savedIndex < self.cgList.length) {
          self.cgIndex = savedIndex;
          self.currentCG = self.cgList[self.cgIndex];
        }
      }
    });
  },

  saveCGIndex() {
    const self = this;
    storage.set({
      key: 'cgLastIndex',
      value: String(self.cgIndex),
      fail: function(error) {
        console.error('CG索引保存失败:', error);
      }
    });
  },

  initImages() {
    if (this.cgList.length > 0) this.currentCG = this.cgList[0];
    if (this.characterList.length > 0) this.currentChar = this.characterList[0];
    if (this.backgroundList.length > 0) this.currentBg = this.backgroundList[0];
  },

  // ================= 页面切换方法 =================
  hidcgui(){
    this.cguishow = !this.cguishow;
  },
  hidlhch(){
    this.lhchshow = !this.lhchshow;
  },
  hidlhui(){
    this.lhuishow = !this.lhuishow;
  },
  showcg() {
    this.jump = false;
    this.cgshow = true;
    this.lhshow = false;
    if (this.cgList.length > 0 && this.cgIndex < this.cgList.length) {
      this.currentCG = this.cgList[this.cgIndex];
    }
  },

  showlh() {
    this.jump = false;
    this.cgshow = false;
    this.lhshow = true;
    if (this.characterList.length > 0 && this.charIndex < this.characterList.length) {
      this.currentChar = this.characterList[this.charIndex];
    }
    if (this.backgroundList.length > 0 && this.bgIndex < this.backgroundList.length) {
      this.currentBg = this.backgroundList[this.bgIndex];
    }
  },

  // ================= 图片切换方法 =================

  // 通用图片切换方法
  switchImage(listName, indexName, currentName, direction, callback) {
    const list = this[listName];
    if (list.length === 0) return;
    this[indexName] = (this[indexName] + direction + list.length) % list.length;
    this[currentName] = list[this[indexName]];
    if (callback) callback();
  },

  // CG切换
  lastcg() { this.switchImage('cgList', 'cgIndex', 'currentCG', -1, () => this.saveCGIndex()); },
  entercg() { this.switchImage('cgList', 'cgIndex', 'currentCG', 1, () => this.saveCGIndex()); },

  // 立绘切换
  lastlh() { this.switchImage('characterList', 'charIndex', 'currentChar', -1); },
  enterlh() { this.switchImage('characterList', 'charIndex', 'currentChar', 1); },

  // 背景切换
  lastcgb() { this.switchImage('backgroundList', 'bgIndex', 'currentBg', -1); },
  entercgb() { this.switchImage('backgroundList', 'bgIndex', 'currentBg', 1); },

  back() {
    if (this.jump === true) {
      router.back({ uri: 'pages/more' });
    } else {
      this.jump = true;
      this.cgshow = false;
      this.lhshow = false;
    }
  },

  // 长按快速切换相关
  autoSwitchTimer: null,
  autoSwitchStopTimer: null,
  autoSwitchDelay: 300,
  switchDirection: null,

  clickLastCG() {
    this.stopAutoSwitch();
    this.lastcg();
  },
  clickNextCG() {
    this.stopAutoSwitch();
    this.entercg();
  },
  clickLastBg() {
    this.stopAutoSwitch();
    this.lastcgb();
  },
  clickNextBg() {
    this.stopAutoSwitch();
    this.entercgb();
  },
  clickLastChar() {
    this.stopAutoSwitch();
    this.lastlh();
  },
  clickNextChar() {
    this.stopAutoSwitch();
    this.enterlh();
  },
  doAutoSwitch() {
    const self = this;
    if (!self.switchDirection) return;
    if (self.switchDirection === 'last') {
      self.lastcg();
    } else if (self.switchDirection === 'next') {
      self.entercg();
    }
    self.autoSwitchDelay = Math.max(50, self.autoSwitchDelay - 20);
    self.autoSwitchTimer = setTimeout(function() {
      self.doAutoSwitch();
    }, self.autoSwitchDelay);
  },
  startLastCG() {
    this.stopAutoSwitch();
    this.switchDirection = 'last';
    this.autoSwitchDelay = 300;
    this.lastcg();
    this.doAutoSwitch();
    this.autoSwitchStopTimer = setTimeout(function() {
      this.stopAutoSwitch();
    }.bind(this), 3000);
  },
  startNextCG() {
    this.stopAutoSwitch();
    this.switchDirection = 'next';
    this.autoSwitchDelay = 300;
    this.entercg();
    this.doAutoSwitch();
    this.autoSwitchStopTimer = setTimeout(function() {
      this.stopAutoSwitch();
    }.bind(this), 3000);
  },
  startLastBg() {
    this.stopAutoSwitch();
    this.lastcgb();
    this.autoSwitchTimer = setInterval(() => { this.lastcgb(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  startNextBg() {
    this.stopAutoSwitch();
    this.entercgb();
    this.autoSwitchTimer = setInterval(() => { this.entercgb(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  startLastChar() {
    this.stopAutoSwitch();
    this.lastlh();
    this.autoSwitchTimer = setInterval(() => { this.lastlh(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  startNextChar() {
    this.stopAutoSwitch();
    this.enterlh();
    this.autoSwitchTimer = setInterval(() => { this.enterlh(); }, 200);
    this.autoSwitchStopTimer = setTimeout(() => { this.stopAutoSwitch(); }, 5000);
  },
  stopAutoSwitch() {
    if (this.autoSwitchTimer) {
      clearTimeout(this.autoSwitchTimer);
      this.autoSwitchTimer = null;
    }
    if (this.autoSwitchStopTimer) {
      clearTimeout(this.autoSwitchStopTimer);
      this.autoSwitchStopTimer = null;
    }
    this.autoSwitchDelay = 300;
    this.switchDirection = null;
  }
};
</script>

