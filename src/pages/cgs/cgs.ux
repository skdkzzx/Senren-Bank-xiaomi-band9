  z-index: 10;
}

.info-text {
  font-size: 22px;
  color: #ffffff;
  text-align: center;
}

.btn-container {
  position: absolute;
  bottom: 55px;
  width: 192px;
  height: 50px;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  z-index: 15;
}

.nav-btn {
  width: 50px;
