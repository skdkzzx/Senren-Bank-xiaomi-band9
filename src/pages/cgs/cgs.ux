<template>
  <div class="page">
    <img class="bcg" src="/common/bcgi/空_夕空.jpg"></img>
    <img class="bt" src="/common/bt.png"></img>
    <img class="hd" src="/common/hd.png"></img>

    <!-- 主菜单 -->
    <div class="page2" if="{{jump === true}}">
      <div class="header header-menu">
        <text class="title">鉴赏模式</text>
      </div>
      <div class="content" onclick="showcg">
        <text class="mid">CG鉴赏</text>
      </div>
      <div class="content" onclick="showlh">
        <text class="mid">立绘鉴赏</text>
      </div>
    </div>

    <!-- CG鉴赏页面 -->
    <div class="page2" if="{{cgshow === true}}">
      <scroll class="cgscroll" scroll-x="true" scroll-y="false" bounces="false">
        <image class="cgimg" src="{{currentCG}}" onclick="hidcgui"></image>
      </scroll>
      <img class="bt" src="/common/bt.png" if="{{cguishow}}"></img>
      <img class="hd" src="/common/hd.png" if="{{cguishow}}"></img>
      <div class="header">
        <text class="title" if="{{cguishow}}">CG鉴赏</text>
      </div>

      <div class="info-container" if="{{cguishow}}">
        <text class="info-text">{{cgIndex + 1}}/{{cgList.length}}</text>
      </div>

      <div class="btn-container" if="{{cguishow}}">
        <div class="nav-btn" onclick="clickLastCG" onlongpress="startLastCG">
          <img src="/common/back.png"></img>
        </div>
        <div class="nav-btn" onclick="clickNextCG" onlongpress="startNextCG">
          <img src="/common/go.png"></img>
        </div>
      </div>
    </div>

    <!-- 立绘鉴赏页面 -->
    <div class="page2" if="{{lhshow === true}}">
      <scroll class="lhscroll" scroll-x="true" scroll-y="false" bounces="false">
        <div class="lhcontent">
          <image class="backgroundimg" src="{{currentBg}}" onclick="hidlhch"></image>
          <image class="character" src="{{currentChar}}" onclick="hidlhui" if="{{lhchshow}}"></image>
        </div>
      </scroll>
      <img class="bt" src="/common/bt.png" if="{{lhuishow}}"></img>
      <img class="hd" src="/common/hd.png" if="{{lhuishow}}"></img>
      <div class="header">
        <text class="title" if="{{lhuishow}}">立绘鉴赏</text>
      </div>
      <div class="info-container" if="{{lhuishow}}">
        <text class="info-text">背景: {{bgIndex + 1}}/{{backgroundList.length}}</text>
        <text class="info-text">角色: {{charIndex + 1}}/{{characterList.length}}</text>
      </div>
      <div class="btn-container" if="{{lhuishow}}">
        <div class="nav-btn" onclick="clickLastBg" onlongpress="startLastBg">
          <img src="/common/back.png"></img>
        </div>
        <div class="nav-btn" onclick="clickNextBg" onlongpress="startNextBg">
          <img src="/common/go.png"></img>
        </div>
        <div class="nav-btn" onclick="clickLastChar" onlongpress="startLastChar">
          <img src="/common/back.png"></img>
        </div>
        <div class="nav-btn" onclick="clickNextChar" onlongpress="startNextChar">
          <img src="/common/go.png"></img>
        </div>
      </div>
    </div>

    <div class="back-btn-wrap" if="{{jump || (cgshow && cguishow) || (lhshow && lhuishow)}}" onclick="back">
      <text class="back-btn-text">返回</text>
    </div>
  </div>
</template>

