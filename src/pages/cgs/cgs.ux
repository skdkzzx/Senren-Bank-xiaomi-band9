}

.cgimg {
  width: 336px;
  height: 490px;
  object-fit: cover;
}

.character {
  position: absolute;
  top: 65px;
  left: 98px;
  width: 140px;
  height: 360px;
  object-fit: contain;
  z-index: 3;
}

.lhscroll {
  width: 192px;
  height: 490px;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.lhcontent {
  width: 336px;
  height: 490px;
  position: relative;
}

.backgroundimg {
  position: absolute;
  width: 336px;
