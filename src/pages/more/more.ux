<template>
  <div class="page">
    <img class="bcg" src="/common/bcgi/空_夕空.jpg"></img>
    <img class="bt" src="/common/bt.png"></img>
    <img class="hd" src="/common/hd.png"></img>

    <scroll id="mainScroll" class="scroll" scroll-y="{{true}}" if="{{!showAS}}">
      <div class="header">
        <text class="title">更多</text>
      </div>
      <div class="content" onclick="lctruote">
        <text class="mid">流程图</text>
      </div>
      <div class="content" onclick="cgruote">
        <text class="mid">鉴赏模式</text>
      </div>
      <div class="content" onclick="afterstoryshow">
        <text class="mid">后日谈</text>
      </div>
    </scroll>

    <div class="page1" if="{{showAS}}">
      <img class="bcg" src="/common/bcgi/空_夕空.jpg"></img>
      <img class="bt" src="/common/bt.png"></img>
      <img class="hd" src="/common/hd.png"></img>

      <div class="header">
        <text class="title">后日谈</text>
      </div>

      <swiper class="as-swiper" index="{{asIndex}}" indicator="false" loop="true" onchange="onSwiperChange">
        <div class="as-page" for="{{afterStories}}" tid="name">
          <image class="cig" src="{{$item.img}}"></image>
          <text class="mid1">{{$item.name}}</text>
          <div class="startBtn">
            <text class="startText" onclick="loadStart($item.line)">开始</text>
          </div>
        </div>
      </swiper>
    </div>

    <!-- 返回按钮 -->
    <div class="back-btn-wrap" onclick="back">
      <text class="back-btn-text">返回</text>
    </div>
  </div>
</template>

<script>
import storage from '@system.storage'
import router from '@system.router'

export default {
  data: {
    showAS: false,
    asIndex: 0,
    afterStories: [
      { name: '芳乃', img: '/common/cimg/fn05_1.png', line: 18291 },
      { name: '茉子', img: '/common/cimg/mz06_1.png', line: 27530 },
      { name: '丛雨', img: '/common/cimg/cy02_1.png', line: 38391 },
      { name: '蕾娜', img: '/common/cimg/ln01_1.png', line: 48184 },
      { name: '小春', img: '/common/cimg/xc02_1.png', line: 53483 },
      { name: '芦花', img: '/common/cimg/lh01_1.png', line: 55422 }
    ]
  },

  onSwiperChange(e) {
    this.asIndex = e.index
  },

  back() {
    if (!this.showAS) {
      router.back({ uri: 'pages/index' })
    } else {
      this.showAS = false
    }
  },

  lctruote() {
    router.push({ uri: 'pages/lct' })
  },

  cgruote() {
    router.push({ uri: 'pages/cgs' })
  },

  afterstoryshow() {
    this.showAS = true
  },

  loadStart(a) {
    storage.set({
      key: 'readProgress',
      value: a.toString(),
      success: () => {},
      fail: () => {}
    })
    router.replace({ uri: 'pages/detail' })
  }
}
</script>

