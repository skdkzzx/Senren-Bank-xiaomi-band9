  }
  .back-btn {
    position: absolute;
    left: 15px;
    top: 15px;
  }
</style>

<script>
  import storage from '@system.storage'
  import router from '@system.router'

  export default {
    data: {
      showAS: false,
      character: 1
    },
    last() {
      if (this.character > 1) {
        this.character -= 1
      } else if (this.character == 1) {
        this.character = 6
      }
    },
    enter() {
      if (this.character < 6) {
        this.character += 1
      } else if (this.character == 6) {
        this.character = 1
      }
    },
    back() {
      if (this.showAS) {
        this.showAS = false
      } else {
        router.back({ uri: 'pages/index' })
      }
    },
    lctruote() {
      router.push({ uri: 'pages/lct' })
    },
    cgruote() {
      router.push({ uri: 'pages/cgs' })
    },
    afterstoryshow() {
      this.showAS = true
    },
    async loadStart(progress) {
      try {
        await new Promise((resolve, reject) => {
          storage.set({
            key: 'readProgress',
            value: progress.toString(),
            success: resolve,
            fail: reject
          })
        })
        console.log('进度设置成功')
        router.push({ uri: 'pages/detail' })
      } catch (e) {
        console.error('进度设置失败:', e)
      }
    }
  }
</script>
