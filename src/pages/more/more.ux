  font-weight: 800;
}

.mid1 {
  text-align: center;
  width: 192px;
  background-color: #fff6e6;
  font-size: 32px;
  color: #645f15;
  font-weight: 800;
  position: absolute;
  bottom: 70px;
}

.startBtn {
  position: absolute;
  bottom: 23px;
  left: 0;
  width: 192px;
  justify-content: center;
  align-items: center;
  padding: 10px 0;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 0;
